---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto | El Garaje de las Guitarras" description="Contacto de El Garaje de las Guitarras: escribinos para consultas, consignaciones o para agendar una visita a La Sala de Pruebas en Buenos Aires.">
    <div class="w-full max-w-7xl mx-auto px-4 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

            <!-- Contact Info -->
            <div class="flex flex-col gap-10">
                <div>
                    <h1 class="font-serif text-4xl md:text-6xl font-black text-slate-100 tracking-wide mb-6">
                        Contacto</h1>
                    <p class="text-slate-400 text-lg leading-relaxed max-w-md">Para consultas sobre instrumentos,
                        consignaciones o para agendar una visita a nuestro Bunker, completá el formulario o
                        contactanos directamente.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-accent-dark/30 p-6 border border-primary/10 rounded-sm">
                        <span class="material-symbols-outlined text-primary text-3xl mb-4">location_on</span>
                        <h3 class="font-serif text-xl font-bold text-slate-200 mb-2">La Sala de Pruebas</h3>
                        <p class="text-slate-400 text-sm">Buenos Aires, Argentina<br />(Dirección exacta por privado)</p>
                        <p class="text-primary text-xs font-bold uppercase tracking-widest mt-4">Solo con cita previa</p>
                    </div>
                    <div class="bg-accent-dark/30 p-6 border border-primary/10 rounded-sm">
                        <span class="material-symbols-outlined text-primary text-3xl mb-4">mail</span>
                        <h3 class="font-serif text-xl font-bold text-slate-200 mb-2">Consultas</h3>
                        <p class="text-slate-400 text-sm">info@El Garajeinstrumentos.com</p>
                        <p class="text-slate-400 text-sm mt-1">+54 9 11 1234-5678</p>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="bg-accent-dark/20 p-8 md:p-12 border border-primary/20 rounded-sm shadow-2xl relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-3xl -mr-16 -mt-16">
                </div>
                <h2 class="font-serif text-2xl font-bold text-slate-100 mb-4 relative z-10">Envianos un mensaje</h2>
                <p id="form-status" class="text-sm text-primary mb-4 hidden relative z-10"></p>
                <form id="contact-form" class="flex flex-col gap-6 relative z-10" action="#" method="post" novalidate>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label for="nombre" class="text-xs font-bold text-slate-400 uppercase tracking-widest">Nombre</label>
                            <input id="nombre" name="nombre" type="text"
                                class="bg-background-dark/50 border border-primary/20 rounded-sm px-4 py-3 text-slate-200 focus:border-primary focus:ring-1 focus:ring-primary transition-colors outline-none"
                                required>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="email" class="text-xs font-bold text-slate-400 uppercase tracking-widest">Email</label>
                            <input id="email" name="email" type="email"
                                class="bg-background-dark/50 border border-primary/20 rounded-sm px-4 py-3 text-slate-200 focus:border-primary focus:ring-1 focus:ring-primary transition-colors outline-none"
                                required>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label for="asunto" class="text-xs font-bold text-slate-400 uppercase tracking-widest">Asunto</label>
                        <select id="asunto" name="asunto"
                            class="bg-background-dark/50 border border-primary/20 rounded-sm px-4 py-3 text-slate-200 focus:border-primary focus:ring-1 focus:ring-primary transition-colors outline-none appearance-none">
                            <option value="instrumento">Consulta sobre instrumento</option>
                            <option value="visita">Agendar visita al Bunker</option>
                            <option value="consignar">Consignar un instrumento</option>
                            <option value="otro">Otro</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label for="mensaje" class="text-xs font-bold text-slate-400 uppercase tracking-widest">Mensaje</label>
                        <textarea id="mensaje" name="mensaje" rows="4"
                            class="bg-background-dark/50 border border-primary/20 rounded-sm px-4 py-3 text-slate-200 focus:border-primary focus:ring-1 focus:ring-primary transition-colors outline-none resize-none"
                            required></textarea>
                    </div>
                    <button type="submit"
                        class="mt-4 h-14 bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all border border-primary rounded-sm flex items-center justify-center gap-2">
                        Enviar Mensaje <span class="material-symbols-outlined text-lg">send</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    // Needs to re-run on astro:page-load for View Transitions support
    document.addEventListener('astro:page-load', () => {
        initContactForm();
    });

    initContactForm();

    function initContactForm() {
        const contactForm = document.getElementById('contact-form') as HTMLFormElement;
        const statusEl = document.getElementById('form-status');

        if (contactForm && statusEl) {
            contactForm.addEventListener('submit', (event) => {
                event.preventDefault();

                const formData = new FormData(contactForm);
                const nombre = String(formData.get('nombre') || '').trim();
                const email = String(formData.get('email') || '').trim();
                const mensaje = String(formData.get('mensaje') || '').trim();

                if (!nombre || !email || !mensaje) {
                    statusEl.textContent = 'Por favor completá todos los campos obligatorios.';
                    statusEl.classList.remove('hidden');
                    statusEl.classList.remove('text-primary');
                    statusEl.classList.add('text-red-400');
                    return;
                }

                // Show success message
                contactForm.reset();
                statusEl.textContent = 'Gracias, recibimos tu mensaje. Te contactaremos a la brevedad.';
                statusEl.classList.remove('hidden');
                statusEl.classList.remove('text-red-400');
                statusEl.classList.add('text-primary');
            });
        }
    }
</script>
