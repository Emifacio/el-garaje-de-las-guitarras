---
export const prerender = false;
import BaseHead from '../../components/layout/BaseHead.astro';
import type { User } from '@supabase/supabase-js';
import { applyAdminNoStore, createAdminRedirect, getAdminAccess } from '../../lib/admin';
import { createSupabaseServerClient } from '../../lib/supabase-server';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
applyAdminNoStore(Astro.response.headers);
let error = Astro.url.searchParams.get('error');
let errorDetail: string | null = null;

console.info('[Admin Login] request', {
  method: Astro.request.method,
  url: Astro.request.url,
  forwardedProto: Astro.request.headers.get('x-forwarded-proto'),
  hasCookieHeader: Boolean(Astro.request.headers.get('cookie')),
});

type AdminProfile = {
  id: string;
  is_admin: boolean;
  full_name: string | null;
  username: string | null;
};

async function getAdminProfile(user: User) {
  const { data: profile, error: profileError } = await supabase
    .from('profiles')
    .select('id, is_admin, full_name, username')
    .eq('id', user.id)
    .maybeSingle<AdminProfile>();

  return { profile, profileError };
}

// Handle the login POST request natively in the page
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString().trim();
    const password = formData.get('password')?.toString();

    if (!email || !password) {
      console.warn('[Admin Login] missing_credentials', {
        url: Astro.request.url,
        hasEmail: Boolean(email),
        hasPassword: Boolean(password),
      });
      error = 'missing_credentials';
    } else {
      console.info('[Admin Login] attempting sign in', {
        url: Astro.request.url,
        email,
      });
      const { data: authData, error: authError } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (authError) {
        console.error('[Admin Login] signInWithPassword failed:', authError.message);
        error = 'invalid_credentials';
        errorDetail = authError.message;
      } else {
        // Avoid re-checking auth with the original request cookies in this same POST.
        // The new session cookies are only guaranteed on the response we are building now.
        const signedInUser = authData.user;
        console.info('[Admin Login] signInWithPassword succeeded', {
          email,
          userId: signedInUser?.id ?? null,
          hasSession: Boolean(authData.session),
        });
        const { profile, profileError } = signedInUser ? await getAdminProfile(signedInUser) : { profile: null, profileError: null };

        if (profileError) {
          console.error('[Admin Login] profile lookup failed after login:', profileError.message);
          await supabase.auth.signOut();
          error = 'profile_error';
          errorDetail = profileError.message;
        } else if (!signedInUser) {
          console.error('[Admin Login] sign-in returned no user payload');
          await supabase.auth.signOut();
          error = 'unexpected_error';
          errorDetail = 'Supabase did not return a user after sign-in.';
        } else if (!profile?.is_admin) {
          console.error('[Admin Login] signed-in user is missing admin access:', {
            userId: signedInUser.id,
            hasProfile: Boolean(profile),
            profileId: profile?.id ?? null,
            isAdmin: profile?.is_admin ?? null,
          });
          await supabase.auth.signOut();
          error = 'not_admin';
        } else {
          console.info('[Admin Login] admin login successful', {
            userId: signedInUser.id,
            profileId: profile.id,
            email: signedInUser.email ?? email,
          });
          return createAdminRedirect('/admin');
        }
      }
    }
  } catch (unexpectedError) {
    console.error('[Admin Login] unexpected error:', unexpectedError);
    error = 'unexpected_error';
  }
}

// Redirect to dashboard only for confirmed admins.
if (Astro.request.method !== 'POST') {
  const adminAccess = await getAdminAccess(supabase);

  if (!adminAccess.ok) {
    console.warn('[Admin Login] existing session check failed', {
      url: Astro.request.url,
      reason: adminAccess.reason,
      error: adminAccess.error ?? null,
    });
  }

  if (adminAccess.ok) {
    return createAdminRedirect('/admin');
  }

  if (adminAccess.reason === 'forbidden' || adminAccess.reason === 'missing_profile') {
    await supabase.auth.signOut();
    error = error ?? 'not_admin';
  } else if (adminAccess.reason === 'profile_lookup_failed') {
    error = error ?? 'profile_error';
  }
}
---
<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <BaseHead title="Login | El Garaje de las Guitarras" />
</head>
<body class="bg-background-dark text-slate-100 font-display min-h-screen flex selection:bg-primary/30 items-center justify-center">

    <div class="w-full max-w-md p-8 bg-background-light/5 border border-primary/20 rounded-sm shadow-2xl relative overflow-hidden group">
        <!-- Decoration -->
        <div class="absolute -top-1/2 -left-1/2 w-full h-full bg-primary/10 blur-3xl rounded-full transform rotate-12 opacity-50"></div>
        
        <div class="relative z-10 flex flex-col items-center">
            <a href="/" class="font-serif text-3xl font-black tracking-widest text-primary uppercase drop-shadow-md mb-8 inline-block">El Garaje</a>
            <h1 class="text-xl font-bold tracking-wide text-slate-200 mb-8 border-b-2 border-primary/50 pb-2 w-full text-center">
                Acceso Administrador
            </h1>

            {error && (
                <div class="w-full bg-red-900/30 border border-red-500/50 text-red-200 p-3 rounded text-sm mb-6 text-center">
                    {error === 'invalid_credentials' && 'Credenciales incorrectas.'}
                    {error === 'missing_credentials' && 'Completa email y contraseña antes de ingresar.'}
                    {error === 'not_admin' && 'Tu usuario existe, pero no tiene permisos de administrador.'}
                    {error === 'profile_error' && 'No pudimos validar tu perfil de administrador. Revisa la configuración de Supabase.'}
                    {error === 'unexpected_error' && 'Ocurrió un error inesperado al iniciar sesión.'}
                    {!['invalid_credentials', 'missing_credentials', 'not_admin', 'profile_error', 'unexpected_error'].includes(error) && 'Ocurrió un error al iniciar sesión.'}
                    {errorDetail && <div class="mt-2 text-xs text-red-100/80 break-words">{errorDetail}</div>}
                </div>
            )}

            <form method="post" class="w-full flex flex-col gap-6" data-astro-reload>
                <div class="flex flex-col gap-2">
                    <label for="email" class="text-xs font-bold uppercase tracking-widest text-slate-400">Email</label>
                    <input type="email" name="email" id="email" required
                        autocomplete="username"
                        class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-slate-200"
                        placeholder="admin@elgaraje.com" />
                </div>
                
                <div class="flex flex-col gap-2">
                    <label for="password" class="text-xs font-bold uppercase tracking-widest text-slate-400">Contraseña</label>
                    <input type="password" name="password" id="password" required
                        autocomplete="current-password"
                        class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-slate-200"
                        placeholder="••••••••" />
                </div>

                <button type="submit" id="submitBtn"
                    class="mt-4 w-full h-12 flex items-center justify-center bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all rounded-sm shadow-lg shadow-primary/20">
                    Ingresar <span class="material-symbols-outlined ml-2">login</span>
                </button>
            </form>
            
            <a href="/" class="mt-8 text-xs text-slate-400 hover:text-primary transition-colors flex items-center gap-1">
                <span class="material-symbols-outlined text-[1rem]">arrow_back</span> Volver al sitio web
            </a>
        </div>
    </div>
</body>
</html>
