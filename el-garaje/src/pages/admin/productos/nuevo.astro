---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase-server';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);

// Verify session
const { data: { session } } = await supabase.auth.getSession();
if (!session) {
    return Astro.redirect('/admin/login');
}

// Fetch categories for the dropdown
const { data: categories } = await supabase
    .from('categories')
    .select('id, name')
    .order('name');

let errorMsg = '';
let successMsg = '';

// Handle Form Submission
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        
        // 1. Extract and validate base fields
        const title = formData.get('title')?.toString().trim();
        const slug = formData.get('slug')?.toString().trim() || title?.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
        const category_id = formData.get('category_id')?.toString();
        const priceStr = formData.get('price')?.toString();
        const price = priceStr ? parseFloat(priceStr) : null;
        const status = formData.get('status')?.toString() || 'disponible';
        
        if (!title || !slug || !category_id) {
            throw new Error('El título, el slug y la categoría son obligatorios.');
        }

        // 2. Build the Product object for insertion
        const newProduct = {
            title,
            slug,
            category_id,
            status,
            price,
            price_display: formData.get('price_display')?.toString() || null,
            brand: formData.get('brand')?.toString() || null,
            year: formData.get('year') ? parseInt(formData.get('year')!.toString()) : null,
            short_description: formData.get('short_description')?.toString() || null,
            long_description: formData.get('long_description')?.toString() || null,
            badge: formData.get('badge')?.toString() || null,
            is_featured: formData.get('is_featured') === 'on',
            sort_order: parseInt(formData.get('sort_order')?.toString() || '0')
        };

        // 3. Insert Product Document
        const { data: insertedProduct, error: insertError } = await supabase
            .from('products')
            .insert(newProduct)
            .select()
            .single();

        if (insertError) throw insertError;

        // 4. Handle Submitting Images (if any are present)
        const imageFiles = formData.getAll('images') as File[];
        // Filter out empty ghost files often submitted by empty <input type="file">
        const validImages = imageFiles.filter(file => file.size > 0 && file.name);

        if (validImages.length > 0 && insertedProduct) {
            let uploadedImages = [];
            let sortOrderCounter = 0;

            // Use strict sequential loop to prevent Vercel from killing the lambda function early
            for (let i = 0; i < validImages.length; i++) {
                const file = validImages[i];
                const fileExt = file.name.split('.').pop();
                const fileName = `${insertedProduct.id}/${crypto.randomUUID()}.${fileExt}`;
                
                const { error: uploadError, data } = await supabase.storage
                    .from('product-images')
                    .upload(fileName, file);

                if (uploadError) {
                    console.error("Image Upload Error:", uploadError);
                    throw new Error(`Error al subir imagen ${file.name}: ${uploadError.message}`);
                }

                if (data?.path) {
                    uploadedImages.push({
                        product_id: insertedProduct.id,
                        storage_path: data.path,
                        sort_order: sortOrderCounter
                    });
                    sortOrderCounter += 10;
                }
            }
            
            if (uploadedImages.length > 0) {
                const { error: imagesError } = await supabase.from('product_images').insert(uploadedImages);
                if (imagesError) {
                    console.error("Database Error (product_images):", imagesError);
                    throw new Error(`Los archivos se subieron pero no pudieron vincularse al producto: ${imagesError.message}`);
                }
            }
        }

        successMsg = `¡Producto "${newProduct.title}" agregado con éxito! Redirigiendo...`;
        
        // Optional: Redirect back to the index after a short delay
        // We will do a direct redirect handled dynamically below
    } catch (err: any) {
        errorMsg = err.message || 'Ocurrió un error inesperado al guardar el producto.';
        console.error("Product Creation Error:", err);
    }
}
---

<AdminLayout title="Nuevo Producto">
    <div class="mb-8 flex items-center gap-4">
        <a href="/admin/productos" class="w-10 h-10 flex items-center justify-center rounded-full bg-background-dark/50 border border-primary/20 text-slate-400 hover:text-primary transition-colors hover:border-primary/50">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="font-serif text-3xl font-black text-slate-100 tracking-wide mb-1">Nuevo Producto</h1>
            <p class="text-slate-400 text-sm">Añadir una guitarra o accesorio nuevo al catálogo.</p>
        </div>
    </div>

    {errorMsg && (
        <div class="mb-6 p-4 bg-red-900/20 border border-red-500/30 text-red-300 rounded text-sm flex items-center gap-2">
            <span class="material-symbols-outlined">error</span> {errorMsg}
        </div>
    )}

    {successMsg ? (
        <div class="mb-6 p-8 bg-emerald-900/20 border border-emerald-500/30 text-emerald-300 rounded text-center flex flex-col items-center gap-4">
            <span class="material-symbols-outlined text-5xl">check_circle</span>
            <div>
                <h3 class="font-bold text-xl mb-2">{successMsg}</h3>
                <p class="text-slate-400">Volviendo al inventario en unos instantes...</p>
            </div>
            <script is:inline>
                setTimeout(() => window.location.href = '/admin/productos', 2000);
            </script>
        </div>
    ) : (
        <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-12">
            
            <!-- Main Content Column -->
            <div class="lg:col-span-2 flex flex-col gap-6">
                <!-- Basic Info Card -->
                <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                    <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Información Básica</h2>
                    
                    <div class="flex flex-col gap-4">
                        <div>
                            <label for="title" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Título del Producto *</label>
                            <input type="text" id="title" name="title" required placeholder="Ej: Gibson Les Paul Custom 1978" 
                                class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors" />
                        </div>
                        
                        <div>
                            <label for="slug" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">URL Fija (Slug)</label>
                            <input type="text" id="slug" name="slug" placeholder="Se genera automáticamente si se deja vacío" 
                                class="w-full bg-background-dark/50 border border-slate-700/50 rounded px-4 py-2.5 text-sm focus:outline-none focus:border-primary/50 text-slate-400 transition-colors" />
                            <p class="text-[10px] text-slate-500 mt-1 mt-1">Identificador único en el navegador (ej: gibson-les-paul-custom). Sólo minúsculas y guiones.</p>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="brand" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Marca</label>
                                <input type="text" id="brand" name="brand" placeholder="Gibson, Fender, Marshall..." 
                                    class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors" />
                            </div>
                            <div>
                                <label for="year" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Año de Fabricación</label>
                                <input type="number" id="year" name="year" placeholder="1978" min="1900" max="2100" 
                                    class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Descriptions Card -->
                <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                    <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Descripciones</h2>
                    
                    <div class="flex flex-col gap-6">
                        <div>
                            <label for="short_description" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Resumen Corto</label>
                            <textarea id="short_description" name="short_description" rows="2" placeholder="Resumen visible en las tarjetas de producto..." 
                                class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors"></textarea>
                        </div>

                        <div>
                            <label for="long_description" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Descripción Detallada (Historia, Estado, Detalles)</label>
                            <textarea id="long_description" name="long_description" rows="8" placeholder="Escribe la historia completa del instrumento aquí..." 
                                class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Media Center -->
                <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                    <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Archivos Multimedia</h2>
                    
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Subir Fotografías</label>
                        <div class="relative w-full border-2 border-dashed border-primary/30 hover:border-primary/60 bg-background-dark/30 rounded-lg p-8 flex flex-col items-center justify-center text-center transition-colors cursor-pointer group">
                            <span class="material-symbols-outlined text-4xl text-primary/50 group-hover:text-primary mb-3 transition-colors">add_photo_alternate</span>
                            <span class="text-slate-300 font-medium font-sm mb-1">Haz clic para seleccionar archivos</span>
                            <span class="text-slate-500 text-xs text-center px-4">Formatos válidos: JPG, PNG, WEBP. Puedes elegir múltiples fotos a la vez.</span>
                            <input type="file" name="images" id="images" multiple accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                        </div>
                        <div id="image-preview" class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-2 empty:hidden">
                            <!-- JS Will populate image previews here -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Preferences Column -->
            <div class="flex flex-col gap-6">

                 <!-- Status & Visibility -->
                 <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                    <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Publicación</h2>
                    
                    <div class="flex flex-col gap-5">
                        <div>
                            <label for="category_id" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Categoría *</label>
                            <select id="category_id" name="category_id" required class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors">
                                <option value="" disabled selected>Selecciona una categoría</option>
                                {categories?.map(c => (
                                    <option value={c.id}>{c.name}</option>
                                ))}
                            </select>
                        </div>

                        <div>
                            <label for="status" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Estado de Venta</label>
                            <select id="status" name="status" class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors">
                                <option value="disponible">Disponible</option>
                                <option value="reservado">Reservado</option>
                                <option value="vendido">Vendido</option>
                            </select>
                        </div>

                        <label class="flex items-center gap-3 p-3 border border-primary/20 rounded-md bg-background-dark/30 hover:bg-primary/5 cursor-pointer transition-colors group">
                            <input type="checkbox" name="is_featured" class="w-4 h-4 rounded border-primary/50 text-primary focus:ring-primary bg-background-dark" />
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-slate-200 group-hover:text-primary transition-colors">Destacar Instrumento</span>
                                <span class="text-xs text-slate-500">Aparecerá iluminado en la portada (Home)</span>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Pricing Card -->
                <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                    <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Precio</h2>
                    
                    <div class="flex flex-col gap-4">
                        <div>
                            <label for="price" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Valor en Dólares (U$D)</label>
                            <input type="number" id="price" name="price" placeholder="Ej: 3500" step="0.01" 
                                class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors font-serif text-lg" />
                        </div>
                        
                        <div>
                            <label for="price_display" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Texto de Precio Alternativo</label>
                            <input type="text" id="price_display" name="price_display" placeholder="Ej: Consultar por permutas" 
                                class="w-full bg-background-dark/50 border border-slate-700/50 rounded px-4 py-2 text-sm focus:outline-none focus:border-primary/50 text-slate-400 transition-colors" />
                            <p class="text-[10px] text-slate-500 mt-1">Si escribes algo aquí, el texto reemplazará al número en la tienda pública.</p>
                        </div>
                        
                        <div>
                            <label for="badge" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Etiqueta Especial (Badge)</label>
                            <input type="text" id="badge" name="badge" placeholder="Ej: Recién Ingresado, Rareza" 
                                class="w-full bg-background-dark/50 border border-slate-700/50 rounded px-4 py-2 text-sm focus:outline-none focus:border-primary/50 text-slate-400 transition-colors" />
                        </div>
                    </div>
                </div>

                <!-- Action Toolbar (Sticky) -->
                <div class="sticky top-20 bg-background-dark border border-primary p-6 rounded-lg shadow-2xl shadow-primary/10">
                    <button type="submit" id="saveBtn" class="w-full h-14 flex items-center justify-center gap-2 bg-primary text-background-dark text-base font-black tracking-widest uppercase hover:bg-primary/90 transition-all rounded shadow-lg shadow-primary/20 hover:scale-[1.02]">
                        <span class="material-symbols-outlined font-normal">save</span>
                        Guardar Producto
                    </button>
                    <p class="text-xs text-center text-slate-500 mt-4">La operación puede demorar si adjuntaste varias fotografías de alta calidad.</p>
                </div>
            </div>
        </form>
    )}
</AdminLayout>

<script>
    // Component logic for View Transitions
    function initNuevoProducto() {
        // Simple script to inject raw Image Previews into the HTML when the user selects files
        const imageInput = document.getElementById('images') as HTMLInputElement;
        const previewContainer = document.getElementById('image-preview');

        imageInput?.addEventListener('change', (e) => {
            if (!previewContainer) return;
            previewContainer.innerHTML = ''; // Clear prev previews

            const files = (e.target as HTMLInputElement).files;
            if (!files || files.length === 0) return;

            Array.from(files).forEach(file => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const url = e.target?.result as string;
                    const div = document.createElement('div');
                    div.className = "aspect-square rounded border border-primary/20 bg-background-dark overflow-hidden";
                    div.innerHTML = `<img src="${url}" class="w-full h-full object-cover opacity-80" alt="Preview" />`;
                    previewContainer.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        });

        const form = document.querySelector('form');
        const btn = document.getElementById('saveBtn');

        form?.addEventListener('submit', async (e) => {
            const imageInput = document.getElementById('images') as HTMLInputElement;
            
            // If already compressed, let native submission happen
            if (imageInput?.dataset.compressed === 'true' || !imageInput?.files || imageInput.files.length === 0) {
                if(btn) {
                    btn.innerHTML = `<span class="material-symbols-outlined animate-spin">refresh</span> Subiendo Datos...`;
                    btn.classList.add('opacity-70', 'pointer-events-none');
                }
                return; 
            }

            // Halt to compress
            e.preventDefault();
            
            if(btn) {
                btn.innerHTML = `<span class="material-symbols-outlined animate-spin">refresh</span> Optimizando fotos...`;
                btn.classList.add('opacity-70', 'pointer-events-none');
            }

            try {
                const dt = new DataTransfer();
                const files = imageInput.files;

                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (file.type.startsWith('image/')) {
                        try {
                            const blob = await compressImage(file);
                            const cleanName = file.name.replace(/\.[^/.]+$/, "") + ".webp";
                            const newFile = new File([blob], cleanName, { type: 'image/webp' });
                            dt.items.add(newFile);
                        } catch (err) {
                            console.error("Compression error for file:", file.name, err);
                            dt.items.add(file); // fallback
                        }
                    } else {
                        dt.items.add(file);
                    }
                }

                imageInput.files = dt.files;
                imageInput.dataset.compressed = 'true';
                
                // Re-trigger submit native
                form.submit();
            } catch(error) {
                console.error("Compression error wrapper:", error);
                // fallback if anything fails hard
                imageInput.dataset.compressed = 'true';
                form.submit();
            }
        });
    }

    // Compressor utility (static, can be outside or inside)
    function compressImage(file: File): Promise<Blob> {
        return new Promise((resolve, reject) => {
            const img = new Image();
            const objectUrl = URL.createObjectURL(file);
            img.src = objectUrl;
            img.onload = () => {
                URL.revokeObjectURL(objectUrl);
                const canvas = document.createElement('canvas');
                const MAX_WIDTH = 1200;
                const MAX_HEIGHT = 1200;
                let width = img.width;
                let height = img.height;

                if (width > height) {
                    if (width > MAX_WIDTH) {
                        height *= MAX_WIDTH / width;
                        width = MAX_WIDTH;
                    }
                } else {
                    if (height > MAX_HEIGHT) {
                        width *= MAX_HEIGHT / height;
                        height = MAX_HEIGHT;
                    }
                }

                canvas.width = width;
                canvas.height = height;
                const ctx = canvas.getContext('2d');
                if(!ctx) return reject('No ctx');
                ctx.drawImage(img, 0, 0, width, height);
                canvas.toBlob((blob) => {
                    if(blob) resolve(blob);
                    else reject('Compression failed');
                }, 'image/webp', 0.85);
            };
            img.onerror = (err) => {
                URL.revokeObjectURL(objectUrl);
                reject(err);
            };
        });
    }

    // Initialize on load and on View Transition navigation
    document.addEventListener('astro:page-load', initNuevoProducto);
</script>
