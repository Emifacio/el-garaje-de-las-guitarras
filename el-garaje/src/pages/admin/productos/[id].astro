---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase-server';
import { requireAdmin, applyAdminHeaders } from '../../../services/auth/requireAdmin';
import { updateProduct, fetchProductForEdit } from '../../../services/products/updateProduct';
import { fetchProductCategories } from '../../../services/products/createProduct';
import { getPublicImageUrl } from '../../../lib/image-utils';
import { formatSoldDateForDisplay } from '../../../lib/dates';

// Initialize Supabase and require admin
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
applyAdminHeaders(Astro.response.headers);

const adminResult = await requireAdmin(supabase);
if (!adminResult.success) {
    return adminResult.redirect;
}

// Get the product ID from URL
const { id } = Astro.params;

if (!id) {
    return Astro.redirect('/admin/productos');
}

let errorMsg = '';
let successMsg = '';
let validationErrors: { field: string; message: string }[] = [];

// Handle Form Submission (Update)
if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    
    const result = await updateProduct(supabase, { productId: id, formData });
    
    if (result.success) {
        if (result.partialFailure && result.partialFailureMessage) {
            successMsg = result.partialFailureMessage;
        } else {
            successMsg = `¡Producto actualizado con éxito!`;
        }
    } else {
        errorMsg = result.errors.join('. ') || 'Ocurrió un error inesperado al actualizar el producto.';
        validationErrors = result.validationErrors || [];
    }
}

// Fetch categories for the dropdown
const categories = await fetchProductCategories(supabase);

// Fetch the existing product data to populate the form
const product = await fetchProductForEdit(supabase, id);

if (!product) {
    return Astro.redirect('/admin/productos');
}

// Sort existing images if present
const sortedImages = product.product_images?.sort((a, b) => a.sort_order - b.sort_order) || [];

// Format sold_date for display
const soldDateDisplay = formatSoldDateForDisplay(product.sold_date);
---

<AdminLayout title={`Editar: ${product.title}`}>
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <a href="/admin/productos" class="w-10 h-10 flex items-center justify-center rounded-full bg-background-dark/50 border border-primary/20 text-slate-400 hover:text-primary transition-colors hover:border-primary/50">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h1 class="font-serif text-3xl font-black text-slate-100 tracking-wide mb-1">Editar Producto</h1>
                <p class="text-slate-400 text-sm">Modificando los datos de este instrumento en el catálogo.</p>
            </div>
        </div>
        <a href={`/producto/${product.slug}`} target="_blank" rel="noopener noreferrer" class="h-10 px-5 flex items-center justify-center gap-2 bg-background-dark text-primary text-sm font-bold tracking-widest uppercase hover:bg-primary/10 transition-all rounded-sm border border-primary/40">
            <span class="material-symbols-outlined text-[1.25rem]">visibility</span> Ver Público
        </a>
    </div>

    {errorMsg && (
        <div class="mb-6 p-4 bg-red-900/20 border border-red-500/30 text-red-300 rounded text-sm flex items-center gap-2">
            <span class="material-symbols-outlined">error</span> {errorMsg}
        </div>
    )}

    {successMsg && (
        <div class="mb-6 p-4 bg-emerald-900/20 border border-emerald-500/30 text-emerald-300 rounded text-sm flex items-center gap-2">
            <span class="material-symbols-outlined">check_circle</span> {successMsg}
        </div>
    )}

    <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-12">
        <!-- Main Content Column -->
        <div class="lg:col-span-2 flex flex-col gap-6">
            <!-- Basic Info Card -->
            <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Información Básica</h2>
                
                <div class="flex flex-col gap-4">
                    <div>
                        <label for="title" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Título del Producto *</label>
                        <input type="text" id="title" name="title" value={product.title} required
                            class={`w-full bg-background-dark/80 border rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors ${validationErrors.find(e => e.field === 'title') ? 'border-red-500' : 'border-primary/30'}`} />
                    </div>
                    
                    <div>
                        <label for="slug" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">URL Fija (Slug)</label>
                        <input type="text" id="slug" name="slug" value={product.slug}
                            class={`w-full bg-background-dark/50 border rounded px-4 py-2.5 text-sm focus:outline-none focus:border-primary/50 text-slate-400 transition-colors ${validationErrors.find(e => e.field === 'slug') ? 'border-red-500' : 'border-slate-700/50'}`} />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="brand" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Marca</label>
                            <input type="text" id="brand" name="brand" value={product.brand || ''}
                                class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors" />
                        </div>
                        <div>
                            <label for="year" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Año</label>
                            <input type="number" id="year" name="year" value={product.year || ''} min="1900" max="2100" 
                                class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Descriptions Card -->
            <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Descripciones</h2>
                
                <div class="flex flex-col gap-6">
                    <div>
                        <label for="short_description" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Resumen Corto</label>
                        <textarea id="short_description" name="short_description" rows="2"
                            class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors">{product.short_description || ''}</textarea>
                    </div>

                    <div>
                        <label for="long_description" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Descripción Detallada</label>
                        <textarea id="long_description" name="long_description" rows="8" 
                            class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors">{product.long_description || ''}</textarea>
                    </div>

                    <div class="pt-4 border-t border-primary/10">
                        <label for="youtube_url" class="flex gap-2 items-center text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">
                            <span class="material-symbols-outlined text-[1.1rem]">smart_display</span> Video de YouTube (Demostración)
                        </label>
                        <input type="url" id="youtube_url" name="youtube_url" value={product.youtube_url || ''} placeholder="https://www.youtube.com/watch?v=..." 
                            class={`w-full bg-background-dark/80 border rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors ${validationErrors.find(e => e.field === 'youtube_url') ? 'border-red-500' : 'border-primary/30'}`} />
                        <p class="text-[10px] text-slate-400 mt-1">Opcional. Pega el enlace completo de YouTube. El video se mostrará en la página del producto.</p>
                    </div>
                </div>
            </div>

            <!-- Existing Images Display -->
            <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Imágenes</h2>
                
                {sortedImages.length > 0 ? (
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
                        {sortedImages.map((img) => (
                            <div class="relative aspect-square rounded border border-primary/30 bg-background-dark overflow-hidden group">
                                <img src={getPublicImageUrl(img.storage_path)} class="w-full h-full object-cover" alt="Product Image" />
                            </div>
                        ))}
                    </div>
                ) : (
                    <p class="text-sm text-slate-400 italic mb-6">No hay imágenes asociadas a este producto.</p>
                )}

                <!-- Upload New Images -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Añadir más fotos</label>
                    <div class="relative w-full border-2 border-dashed border-primary/30 hover:border-primary/60 bg-background-dark/30 rounded-lg p-8 flex flex-col items-center justify-center text-center transition-colors cursor-pointer group">
                        <span class="material-symbols-outlined text-4xl text-primary/50 group-hover:text-primary mb-3 transition-colors">add_photo_alternate</span>
                        <span class="text-slate-300 font-medium font-sm mb-1">Haz clic para añadir archivos</span>
                        <span class="text-slate-400 text-xs text-center px-4">Las fotos nuevas se agregarán al final. Formatos: JPG, PNG, WEBP.</span>
                        <input type="file" name="images" id="images" multiple accept="image/jpeg,image/png,image/webp" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                    </div>
                    <div id="image-preview" class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-2 empty:hidden">
                    </div>
                </div>
                <p class="text-xs text-slate-400 mt-4 border-t border-primary/10 pt-4">Nota: Para eliminar imágenes deberás gestionarlo temporalmente desde el bucket "product-images" en Supabase.</p>
            </div>
        </div>

        <!-- Sidebar Preferences Column -->
        <div class="flex flex-col gap-6">

                <!-- Status & Visibility -->
                <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Publicación</h2>
                
                <div class="flex flex-col gap-5">
                    <div>
                        <label for="category_id" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Categoría *</label>
                        <select id="category_id" name="category_id" required class={`w-full bg-background-dark/80 border rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors ${validationErrors.find(e => e.field === 'category_id') ? 'border-red-500' : 'border-primary/30'}`}>
                            {categories.map(c => (
                                <option value={c.id} selected={product.category_id === c.id}>{c.name}</option>
                            ))}
                        </select>
                    </div>

                    <div>
                        <label for="status" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Estado de Venta</label>
                        <select id="status" name="status" class="w-full bg-background-dark/80 border border-primary/30 rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors">
                            <option value="disponible" selected={product.status === 'disponible'}>Disponible</option>
                            <option value="reservado" selected={product.status === 'reservado'}>Reservado</option>
                            <option value="vendido" selected={product.status === 'vendido'}>Vendido</option>
                        </select>
                    </div>

                    <div id="sold_date_container" class={product.status === 'vendido' ? '' : 'hidden'}>
                        <label for="sold_date" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Fecha de Venta (DD/MM/YYYY)</label>
                        <input type="text" id="sold_date" name="sold_date" placeholder="Ej: 25/12/2024"
                            value={soldDateDisplay}
                            class={`w-full bg-background-dark/80 border rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors ${validationErrors.find(e => e.field === 'sold_date') ? 'border-red-500' : 'border-primary/30'}`} />
                    </div>

                    <label class="flex items-center gap-3 p-3 border border-primary/20 rounded-md bg-background-dark/30 hover:bg-primary/5 cursor-pointer transition-colors group">
                        <input type="checkbox" name="is_featured" checked={product.is_featured} class="w-4 h-4 rounded border-primary/50 text-primary focus:ring-primary bg-background-dark" />
                        <div class="flex flex-col">
                            <span class="text-sm font-bold text-slate-200 group-hover:text-primary transition-colors">Destacar Instrumento</span>
                            <span class="text-xs text-slate-400">Aparecerá iluminado en la portada</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Pricing Card -->
            <div class="bg-background-light/5 border border-primary/20 rounded-lg p-6">
                <h2 class="font-serif text-xl font-bold text-slate-200 mb-6 border-b border-primary/10 pb-2">Precio</h2>
                
                <div class="flex flex-col gap-4">
                    <div>
                        <label for="price" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Valor (U$D)</label>
                        <input type="number" id="price" name="price" value={product.price || ''} step="0.01" 
                            class={`w-full bg-background-dark/80 border rounded px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-slate-200 transition-colors font-serif text-lg ${validationErrors.find(e => e.field === 'price') ? 'border-red-500' : 'border-primary/30'}`} />
                    </div>
                    
                    <div>
                        <label for="price_display" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Texto Alternativo</label>
                        <input type="text" id="price_display" name="price_display" value={product.price_display || ''}
                            class="w-full bg-background-dark/50 border border-slate-700/50 rounded px-4 py-2 text-sm focus:outline-none focus:border-primary/50 text-slate-400 transition-colors" />
                    </div>
                    
                    <div>
                        <label for="badge" class="block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Etiqueta (Badge)</label>
                        <input type="text" id="badge" name="badge" value={product.badge || ''}
                            class="w-full bg-background-dark/50 border border-slate-700/50 rounded px-4 py-2 text-sm focus:outline-none focus:border-primary/50 text-slate-400 transition-colors" />
                    </div>
                </div>
            </div>

            <!-- Action Toolbar -->
            <div class="bg-background-dark border border-primary p-6 rounded-lg shadow-2xl shadow-primary/10">
                <button type="submit" id="updateBtn" class="w-full h-14 flex items-center justify-center gap-2 bg-primary text-background-dark text-base font-black tracking-widest uppercase hover:bg-primary/90 transition-all rounded shadow-lg shadow-primary/20 hover:scale-[1.02]">
                    <span class="material-symbols-outlined font-normal">save</span>
                    Guardar Cambios
                </button>
            </div>
        </div>
    </form>
</AdminLayout>

<script>
    import { initImageUpload } from '../../../scripts/admin/product-image-upload';

    function initEditProducto() {
        // Toggle sold date visibility based on status
        const statusSelect = document.getElementById('status') as HTMLSelectElement;
        const soldDateContainer = document.getElementById('sold_date_container');
        
        if (statusSelect && soldDateContainer) {
            statusSelect.addEventListener('change', (e) => {
                if ((e.target as HTMLSelectElement).value === 'vendido') {
                    soldDateContainer.classList.remove('hidden');
                } else {
                    soldDateContainer.classList.add('hidden');
                }
            });
        }
    }

    const cleanup = initImageUpload({
        formSelector: 'form[method="POST"]',
        inputSelector: '#images',
        previewSelector: '#image-preview',
        buttonSelector: '#updateBtn',
        loadingText: `<span class="material-symbols-outlined animate-spin text-sm">refresh</span> Guardando...`,
        compressingText: `<span class="material-symbols-outlined animate-spin text-sm">refresh</span> Optimizando fotos...`,
    });

    document.addEventListener('astro:page-load', initEditProducto);
    document.addEventListener('astro:before-swap', cleanup);
</script>
