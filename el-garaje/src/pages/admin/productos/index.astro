---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase-server';
import { requireAdmin, applyAdminHeaders } from '../../../services/auth/requireAdmin';
import { deleteProduct } from '../../../services/products/deleteProduct';
import { toggleProductStatus } from '../../../services/products/toggleProductStatus';
import { listProducts } from '../../../services/products/listProducts';
import { getPublicImageUrl } from '../../../lib/image-utils';

// Initialize Supabase and require admin
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
applyAdminHeaders(Astro.response.headers);

const adminResult = await requireAdmin(supabase);
if (!adminResult.success) {
    return adminResult.redirect;
}

// Handle POST actions (Delete, Toggle Status)
let actionMessage = '';
let actionError = '';

if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    const action = formData.get('action')?.toString();
    const productId = formData.get('productId')?.toString();

    if (!productId) {
        actionError = 'ID de producto no proporcionado.';
    } else if (action === 'delete') {
        const result = await deleteProduct(supabase, productId);
        if (result.success) {
            actionMessage = 'Producto eliminado exitosamente.';
        } else {
            actionError = result.error || 'Error desconocido al eliminar.';
        }
    } else if (action === 'toggle_status') {
        const currentStatus = formData.get('currentStatus')?.toString() || 'disponible';
        const result = await toggleProductStatus(supabase, productId, currentStatus);
        if (result.success) {
            actionMessage = `Estado cambiado a "${result.newStatus}" exitosamente.`;
        } else {
            actionError = result.error || 'Error desconocido al cambiar estado.';
        }
    }
}

// Fetch all products using service
const { products, error: fetchError } = await listProducts(supabase);
const fetchErrorMessage = fetchError || '';

// Helper to get main image
const getMainImage = (images: any[]) => {
    if (!images || images.length === 0) return null;
    const sorted = [...images].sort((a, b) => a.sort_order - b.sort_order);
    return getPublicImageUrl(sorted[0].storage_path);
};

// Helper for status colors
const getStatusClasses = (status: string) => {
    switch (status) {
        case 'disponible': return 'bg-emerald-900/30 text-emerald-400 border-emerald-500/30';
        case 'reservado': return 'bg-amber-900/30 text-amber-400 border-amber-500/30';
        case 'vendido': return 'bg-red-900/30 text-red-400 border-red-500/30';
        default: return 'bg-slate-800 text-slate-400 border-slate-700';
    }
};

// Helper for next toggle status (3-state cycling)
const getNextStatus = (status: string) => {
    switch (status) {
        case 'disponible': return 'reservado';
        case 'reservado': return 'vendido';
        case 'vendido': return 'disponible';
        default: return 'disponible';
    }
};

const getToggleLabel = (status: string) => {
    switch (status) {
        case 'disponible': return 'Marcar Reservado';
        case 'reservado': return 'Marcar Vendido';
        case 'vendido': return 'Marcar Disponible';
        default: return 'Cambiar Estado';
    }
};

const getToggleIcon = (status: string) => {
    switch (status) {
        case 'disponible': return 'bookmark_add';
        case 'reservado': return 'schedule';
        case 'vendido': return 'check_circle';
        default: return 'swap_horiz';
    }
};
---

<AdminLayout title="Inventario de Productos">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-8 gap-4">
        <div>
            <h1 class="font-serif text-3xl font-black text-slate-100 tracking-wide mb-2">Inventario</h1>
            <p class="text-slate-400">Gestiona las guitarras y accesorios del catálogo.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">
            <div class="relative w-full sm:w-64 lg:w-80">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                <input type="text" id="admin-search" placeholder="Buscar por título, marca o categoría..." class="w-full h-10 pl-10 pr-4 bg-background-light/5 border border-primary/20 rounded-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-primary/50 transition-colors">
            </div>
            <a href="/admin/productos/nuevo" class="h-10 px-5 flex items-center justify-center gap-2 bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all rounded-sm shadow-lg shadow-primary/20 border border-primary w-full sm:w-auto shrink-0">
                <span class="material-symbols-outlined text-[1.25rem]">add</span> Nuevo Producto
            </a>
        </div>
    </div>

    {actionMessage && (
        <div class="mb-6 p-4 bg-emerald-900/20 border border-emerald-500/30 text-emerald-300 rounded text-sm flex items-center gap-2">
            <span class="material-symbols-outlined">check_circle</span> {actionMessage}
        </div>
    )}

    {actionError && (
        <div class="mb-6 p-4 bg-red-900/20 border border-red-500/30 text-red-300 rounded text-sm flex items-center gap-2">
            <span class="material-symbols-outlined">error</span> {actionError}
        </div>
    )}

    <!-- Mobile Card Layout -->
    <div class="flex flex-col gap-4 lg:hidden">
        {products && products.length > 0 ? (
            products.map((product) => {
                const mainImageUrl = getMainImage(product.product_images);
                return (
                    <div class="product-item bg-background-light/5 border border-primary/20 rounded-lg p-4 flex flex-col gap-4" data-search={`${product.title} ${product.brand || ''} ${product.categories?.name || ''}`.toLowerCase()}>
                        <div class="flex items-center gap-4">
                            <div class="w-16 h-16 rounded bg-background-dark border border-primary/20 overflow-hidden flex-shrink-0">
                                {mainImageUrl ? (
                                    <img src={mainImageUrl} alt={product.title} class="w-full h-full object-cover" />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center">
                                        <span class="material-symbols-outlined text-slate-600">image</span>
                                    </div>
                                )}
                            </div>
                            <div class="flex-1 min-w-0 overflow-x-auto">
                                <h3 class="font-bold text-slate-200 whitespace-nowrap">{product.title}</h3>
                                <p class="text-xs text-slate-400">{product.brand || 'Sin marca'} {product.year ? `• ${product.year}` : ''}</p>
                                <p class="text-xs text-slate-400 mt-1">{product.categories?.name || '---'}</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between">
                            <span class="font-serif text-slate-200">
                                {product.price ? `U$D ${product.price.toLocaleString()}` : <span class="text-slate-400 text-sm">N/C</span>}
                            </span>
                            <span class={`text-[10px] font-bold uppercase tracking-widest px-2 py-1 border rounded-sm ${getStatusClasses(product.status)}`}>
                                {product.status}
                            </span>
                        </div>

                        <div class="flex gap-2 flex-wrap">
                            <!-- Quick Status Toggle -->
                            <form method="post" class="flex-1">
                                <input type="hidden" name="action" value="toggle_status" />
                                <input type="hidden" name="productId" value={product.id} />
                                <input type="hidden" name="currentStatus" value={product.status} />
                                <input type="hidden" name="newStatus" value={getNextStatus(product.status)} />
                                <button type="submit" class={`w-full h-10 flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase rounded-sm border transition-all ${
                                    product.status === 'vendido' 
                                        ? 'bg-emerald-900/20 text-emerald-400 border-emerald-500/30 hover:bg-emerald-900/40'
                                        : product.status === 'reservado'
                                            ? 'bg-red-900/20 text-red-400 border-red-500/30 hover:bg-red-900/40'
                                            : 'bg-amber-900/20 text-amber-400 border-amber-500/30 hover:bg-amber-900/40'
                                }`}>
                                    <span class="material-symbols-outlined text-[1rem]">{getToggleIcon(product.status)}</span>
                                    {getToggleLabel(product.status)}
                                </button>
                            </form>

                            <a href={`/admin/productos/${product.id}`} class="h-10 px-4 flex items-center justify-center gap-1 text-slate-400 hover:text-primary transition-colors bg-background-dark/50 rounded border border-primary/20 hover:border-primary/50 text-xs font-bold uppercase tracking-widest">
                                <span class="material-symbols-outlined text-[1rem]">edit</span> Editar
                            </a>

                            <form method="post" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este producto de forma permanente?');">
                                <input type="hidden" name="action" value="delete" />
                                <input type="hidden" name="productId" value={product.id} />
                                <button type="submit" class="h-10 px-4 flex items-center justify-center gap-1 text-red-400 hover:text-red-300 transition-colors bg-red-900/10 rounded border border-red-500/20 hover:border-red-500/40 text-xs font-bold uppercase tracking-widest">
                                    <span class="material-symbols-outlined text-[1rem]">delete_forever</span> Eliminar
                                </button>
                            </form>
                        </div>
                    </div>
                );
            })
        ) : (
            <div class="p-8 text-center text-slate-400 bg-background-light/5 border border-primary/20 rounded-lg">
                No hay productos registrados en la base de datos.
            </div>
        )}
    </div>

    <!-- Desktop Table Layout -->
    <div class="bg-background-light/5 border border-primary/20 rounded-lg overflow-hidden hidden lg:block">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-background-dark/50 border-b border-primary/20">
                        <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-400 w-16">Imagen</th>
                        <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-400">Título / Modelo</th>
                        <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-400">Categoría</th>
                        <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-400">Precio</th>
                        <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-400">Estado</th>
                        <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-400 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-primary/10">
                    {products && products.length > 0 ? (
                        products.map((product) => {
                            const mainImageUrl = getMainImage(product.product_images);
                            return (
                                <tr class="product-item hover:bg-primary/5 transition-colors group" data-search={`${product.title} ${product.brand || ''} ${product.categories?.name || ''}`.toLowerCase()}>
                                    <td class="p-4 align-middle">
                                        <div class="w-12 h-12 rounded bg-background-dark border border-primary/20 overflow-hidden flex items-center justify-center">
                                            {mainImageUrl ? (
                                                <img src={mainImageUrl} alt={product.title} class="w-full h-full object-cover" />
                                            ) : (
                                                <span class="material-symbols-outlined text-slate-600">image</span>
                                            )}
                                        </div>
                                    </td>
                                    <td class="p-4 align-middle">
                                        <div class="font-bold text-slate-200">{product.title}</div>
                                        <div class="text-xs text-slate-400 mt-1">{product.brand || 'Sin marca'} {product.year ? `• ${product.year}` : ''}</div>
                                    </td>
                                    <td class="p-4 align-middle text-slate-400 text-sm">
                                        {product.categories?.name || '---'}
                                    </td>
                                    <td class="p-4 align-middle font-serif text-slate-200">
                                        {product.price ? `U$D ${product.price.toLocaleString()}` : <span class="text-slate-400 text-sm">N/C</span>}
                                    </td>
                                    <td class="p-4 align-middle">
                                        <span class={`text-[10px] font-bold uppercase tracking-widest px-2 py-1 border rounded-sm ${getStatusClasses(product.status)}`}>
                                            {product.status}
                                        </span>
                                    </td>
                                    <td class="p-4 align-middle text-right">
                                        <div class="flex justify-end gap-2">
                                            <!-- Quick Status Toggle -->
                                            <form method="post" class="inline">
                                                <input type="hidden" name="action" value="toggle_status" />
                                                <input type="hidden" name="productId" value={product.id} />
                                                <input type="hidden" name="currentStatus" value={product.status} />
                                                <input type="hidden" name="newStatus" value={getNextStatus(product.status)} />
                                                <button type="submit" class={`p-2 transition-colors bg-background-dark/50 rounded border border-transparent hover:border-primary/30 ${
                                                    product.status === 'vendido' 
                                                        ? 'text-emerald-400 hover:text-emerald-300'
                                                        : product.status === 'reservado'
                                                            ? 'text-red-400 hover:text-red-300'
                                                            : 'text-amber-400 hover:text-amber-300'
                                                }`} title={getToggleLabel(product.status)}>
                                                    <span class="material-symbols-outlined text-[1.25rem]">{getToggleIcon(product.status)}</span>
                                                </button>
                                            </form>
                                            <a href={`/admin/productos/${product.id}`} class="p-2 text-slate-400 hover:text-primary transition-colors bg-background-dark/50 rounded border border-transparent hover:border-primary/30" title="Editar">
                                                <span class="material-symbols-outlined text-[1.25rem]">edit</span>
                                            </a>
                                            <form method="post" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este producto de forma permanente?');">
                                                <input type="hidden" name="action" value="delete" />
                                                <input type="hidden" name="productId" value={product.id} />
                                                <button type="submit" class="p-2 text-red-400 hover:text-red-300 transition-colors bg-background-dark/50 rounded border border-transparent hover:border-red-500/30" title="Eliminar">
                                                    <span class="material-symbols-outlined text-[1.25rem]">delete_forever</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            );
                        })
                    ) : (
                        <tr>
                            <td colspan="6" class="p-8 text-center text-slate-400">
                                No hay productos registrados en la base de datos.
                            </td>
                        </tr>
                    )}
                </tbody>
            </table>
        </div>
    </div>
</AdminLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const searchInput = document.getElementById('admin-search') as HTMLInputElement;
        if (!searchInput) return;

        searchInput.addEventListener('input', (e) => {
            const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
            const items = document.querySelectorAll('.product-item');

            items.forEach((item) => {
                const searchData = (item as HTMLElement).dataset.search || '';
                if (searchData.includes(searchTerm)) {
                    (item as HTMLElement).style.display = '';
                } else {
                    (item as HTMLElement).style.display = 'none';
                }
            });
        });
    });
</script>
