---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ProductGallery from '../../components/product/ProductGallery.astro';
import ProductSpecs from '../../components/product/ProductSpecs.astro';
import StatusBadge from '../../components/product/StatusBadge.astro';
import { getProductBySlug } from '../../lib/queries';
import { generateWhatsAppUrl } from '../../lib/whatsapp';

const { slug } = Astro.params;
const product = await getProductBySlug(slug as string);

if (!product) {
  return new Response("Not Found", { status: 404 });
}

// Format Price — always show value
const priceDisplay = product.price_display || (product.price ? `U$D ${product.price.toLocaleString()}` : 'U$D 9.999.999,99');

// WhatsApp URLs
const reservarUrl = generateWhatsAppUrl('reservar', product.title, product.id);
const comprarUrl = generateWhatsAppUrl('comprar', product.title, product.id);

const isSold = product.status === 'vendido';

// Breadcrumbs Data
const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: product.categories?.name || 'Categoría', url: `/categoria/${product.categories?.slug || ''}` },
  { label: product.title, isCurrent: true }
];

const pageTitle = `${product.title} | El Garaje de las Guitarras`;
---

<BaseLayout 
    title={pageTitle} 
    description={product.seo_description || product.short_description || ''}
>
    <main class="w-full max-w-7xl mx-auto px-4 py-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20">
            <!-- Image Gallery Column -->
            <ProductGallery images={product.product_images || null} title={product.title} isSold={isSold} />

            <!-- Product Detail Column -->
            <div class="flex flex-col">
                <div class="mb-2">
                    <StatusBadge status={product.status} badge={product.badge} />
                </div>

                <h1 class="font-serif text-4xl md:text-5xl font-black text-slate-100 tracking-wide mb-4 leading-tight">
                    {product.title}
                </h1>
                
                <p class={`font-serif text-2xl font-bold mb-8 opacity-90 ${isSold ? 'text-slate-500 line-through' : 'text-primary'}`}>
                    {priceDisplay}
                </p>

                {(product.long_description || product.short_description) && (
                    <div class="text-slate-400 text-lg leading-relaxed mb-10 border-l-[3px] border-primary/50 pl-6 italic">
                        <p>{product.long_description || product.short_description}</p>
                    </div>
                )}

                <!-- CTAs: WhatsApp Pseudo-Checkout -->
                {!isSold ? (
                    <div class="product-footer flex flex-col sm:flex-row gap-4 mb-12">
                        <a href={reservarUrl} 
                           target="_blank" 
                           rel="noopener noreferrer"
                           data-track-type="whatsapp_reservar"
                           data-track-product-id={product.id}
                           data-track-product-title={product.title}
                           class="track-interaction flex-1 h-16 bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all border border-primary rounded-sm flex items-center justify-center gap-3">
                            Reservar <span class="material-symbols-outlined">bookmark</span>
                        </a>
                        <a href={comprarUrl}
                           target="_blank" 
                           rel="noopener noreferrer"
                           data-track-type="whatsapp_comprar"
                           data-track-product-id={product.id}
                           data-track-product-title={product.title}
                           class="track-interaction flex-1 h-16 bg-[#25D366] text-white text-sm font-bold tracking-widest uppercase hover:bg-[#25D366]/90 transition-all border border-[#25D366] rounded-sm flex items-center justify-center gap-3 shadow-lg shadow-[#25D366]/20">
                            Comprar por WhatsApp
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        </a>
                    </div>
                ) : (
                    <div class="mb-12 p-6 bg-accent-burgundy/20 border border-accent-burgundy/40 rounded-sm text-center">
                        <p class="text-slate-300 font-serif text-lg">Este instrumento ya fue vendido</p>
                        <a href="/" class="text-primary text-sm font-bold uppercase tracking-widest mt-3 inline-block hover:text-primary/80 transition-colors">
                            Ver instrumentos disponibles →
                        </a>
                    </div>
                )}

                <!-- Specs -->
                <ProductSpecs product={product} />
            </div>
        </div>
    </main>
</BaseLayout>

<script>
    // Track interactions on WhatsApp buttons
    document.addEventListener('astro:page-load', () => initTracking());
    initTracking();

    function initTracking() {
        const trackButtons = document.querySelectorAll('.track-interaction');
        trackButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const interactionType = btn.getAttribute('data-track-type');
                const productId = btn.getAttribute('data-track-product-id');
                const productTitle = btn.getAttribute('data-track-product-title');

                if (interactionType) {
                    fetch('/api/track-interaction', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            product_id: productId,
                            interaction_type: interactionType,
                            metadata: { product_title: productTitle, timestamp: new Date().toISOString() }
                        })
                    }).catch(err => console.warn('Tracking failed:', err));
                }
            });
        });
    }
</script>
