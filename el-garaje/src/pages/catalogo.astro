---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterSidebar from '../components/category/FilterSidebar.astro';
import ProductCard from '../components/product/ProductCard.astro';
import { getCatalogPage } from '../application/catalog/get-catalog';
import { createSupabaseServerClient } from '../lib/supabase-server';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
const products = await getCatalogPage(supabase);
const pageTitle = 'Catálogo | El Garaje de las Guitarras';

// Split brands: available vs sold-only
const availableBrands = [...new Set(products.filter(p => !p.isSold).map(p => p.brand || 'Otras'))].sort();
const soldOnlyBrands = [...new Set(products.filter(p => p.isSold).map(p => p.brand || 'Otras'))]
    .filter(b => !availableBrands.includes(b))
    .sort();
---

<BaseLayout title={pageTitle} description="Explorá nuestro catálogo completo de guitarras eléctricas, acústicas, bajos, amplificadores y efectos. Tienda boutique El Garaje de las Guitarras.">
    <div class="w-full max-w-7xl mx-auto px-4 py-8">
        <!-- Header -->
        <div class="mb-12 border-b border-primary/20 pb-6">
            <h1 class="font-serif text-4xl md:text-5xl font-black text-slate-100 tracking-wide mb-4">
                Catálogo
            </h1>
            <p class="text-slate-400 max-w-2xl text-lg">
                Toda nuestra colección de instrumentos y equipamiento en un solo lugar.
            </p>
        </div>

        <!-- Filters & Grid -->
        <div class="flex flex-col lg:flex-row gap-12">
            <FilterSidebar brands={availableBrands} soldOnlyBrands={soldOnlyBrands} />

            <div class="flex-1">
                <div id="product-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {products.length > 0 ? (
                        products.map(product => (
                            <ProductCard product={product} />
                        ))
                    ) : (
                        <div class="col-span-full py-12 text-center text-slate-400">
                            <p>No hay productos disponibles actualmente.</p>
                        </div>
                    )}
                </div>

                <!-- Sold Items Toggle -->
                <div id="sold-section" class="mt-10 hidden">
                    <button
                        id="sold-toggle-btn"
                        type="button"
                        class="w-full flex items-center justify-center gap-3 py-4 px-6 border border-primary/20 rounded-sm bg-accent-dark/20 hover:bg-accent-dark/40 transition-all duration-300 group cursor-pointer"
                    >
                        <span class="h-px flex-1 bg-primary/20"></span>
                        <span class="text-sm font-bold text-slate-400 group-hover:text-primary tracking-widest uppercase transition-colors">
                            Vendidos (<span id="sold-count">0</span>)
                        </span>
                        <span id="sold-toggle-icon" class="material-symbols-outlined text-primary/60 group-hover:text-primary transition-all duration-300">
                            expand_more
                        </span>
                        <span class="h-px flex-1 bg-primary/20"></span>
                    </button>

                    <div id="sold-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6 hidden">
                    </div>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    import { CatalogController } from '../ui/catalog/catalog-controller';
    
    document.addEventListener('astro:page-load', () => {
        const controller = new CatalogController();
        controller.init();
    });
</script>
