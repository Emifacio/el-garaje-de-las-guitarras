---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/product/ProductCard.astro';
import { getHomePageFeatured } from '../application/home/get-home-page';

const featuredProducts = await getHomePageFeatured();
---

<BaseLayout title="El Garaje de las Guitarras - Inicio">
    <!-- Hero Carousel -->
    <div class="relative w-full overflow-hidden" id="hero-carousel" aria-label="Hero Carousel" aria-roledescription="carousel">
        <!-- Slides -->
        <div class="flex transition-transform duration-700 ease-in-out" id="carousel-track">
            <!-- Slide 1 -->
            <div class="w-full flex-shrink-0 relative min-h-[550px] md:min-h-[650px] lg:min-h-[720px] flex items-center justify-center bg-cover bg-center bg-no-repeat"
                role="group" aria-roledescription="slide" aria-label="1 de 3"
                style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBe_03E6Jf23rc7P9EMd_egkSpFN1oktVXpcsTf_w4J9Ud-hVEbIH02XbI0G8iBs7nUjX6HQtFdGExmPmWD2_d-j9Sxpslw7PaibxoN3xWEoOlC_5eDMnk0UIqW11Dlgqh1Y4uE2QziWS0-kIAqqM1KZFI2KVvMARdM-OXD7dwTRRJFfhLlQP8ps-Fs9Fg5JdzmV0RxA07cb-w3EkHoqtbexpR_yLZAtciMgFIpUA796KHKB0oNpoEtYrh4HRO5edbm-DS_ajPxxqs');">
                <div class="absolute inset-0 bg-gradient-to-b from-background-dark/70 via-background-dark/40 to-background-dark/95"></div>
                <div class="relative z-10 flex flex-col items-center gap-6 max-w-3xl mx-auto text-center px-6">
                    <span class="text-primary text-xs font-bold tracking-[0.4em] uppercase">El Garaje de las Guitarras</span>
                    <h2 class="font-serif text-slate-50 text-4xl md:text-5xl lg:text-6xl font-black leading-tight tracking-wide drop-shadow-xl">
                        Tienda de Guitarras y Amplis de Media y Alta Gama
                    </h2>
                    <p class="text-slate-300 text-lg md:text-xl font-light tracking-wide max-w-xl">
                        Un ambiente cálido, sin apuros y distendido para encontrar tu próximo instrumento.
                    </p>
                    <div class="flex flex-wrap gap-4 justify-center mt-4">
                        <a href="/catalogo"
                            class="min-w-[180px] h-14 flex items-center justify-center rounded-sm bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all border border-primary shadow-lg shadow-primary/20 px-8">
                            Comprá Ahora
                        </a>
                        <a href="/sobre-elgaraje"
                            class="min-w-[180px] h-14 flex items-center justify-center rounded-sm bg-transparent text-primary text-sm font-bold tracking-widest uppercase hover:bg-primary/10 transition-all border border-primary px-8">
                            Lee Más
                        </a>
                    </div>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="w-full flex-shrink-0 relative min-h-[550px] md:min-h-[650px] lg:min-h-[720px] flex items-center justify-center bg-cover bg-center bg-no-repeat"
                role="group" aria-roledescription="slide" aria-label="2 de 3"
                style="background-image: url('/CoverHero.jpeg');">
                <div class="absolute inset-0 bg-gradient-to-b from-background-dark/70 via-accent-burgundy/30 to-background-dark/95"></div>
                <div class="relative z-10 flex flex-col items-center gap-6 max-w-3xl mx-auto text-center px-6">
                    <span class="text-primary text-xs font-bold tracking-[0.4em] uppercase">Nuestro Garaje</span>
                    <h2 class="font-serif text-slate-50 text-4xl md:text-5xl lg:text-6xl font-black leading-tight tracking-wide drop-shadow-xl">
                        Quiero ir a probar
                    </h2>
                    <p class="text-slate-300 text-lg md:text-xl font-light tracking-wide max-w-xl">
                        Nuestra sala privada, equipada con amplificadores y todo lo que necesitás. Sin presiones.
                    </p>
                    <div class="flex flex-wrap gap-4 justify-center mt-4">
                        <a href="/sobre-elgaraje"
                            class="min-w-[180px] h-14 flex items-center justify-center rounded-sm bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all border border-primary shadow-lg shadow-primary/20 px-8">
                            Nuestro Garaje
                        </a>
                        <a href="/sobre-elgaraje"
                            class="min-w-[180px] h-14 flex items-center justify-center rounded-sm bg-transparent text-primary text-sm font-bold tracking-widest uppercase hover:bg-primary/10 transition-all border border-primary px-8">
                            Lee Más
                        </a>
                    </div>
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="w-full flex-shrink-0 relative min-h-[550px] md:min-h-[650px] lg:min-h-[720px] flex items-center justify-center bg-cover bg-center bg-no-repeat"
                role="group" aria-roledescription="slide" aria-label="3 de 3"
                style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCmqNj2JacPW8EE_E-qKLVFd2oP4mfJq3VmIYFjYW8L2xM0BYsJYVLtClXCx7BWyoXWXnLALONLW-LJclLLCktwER8S4YDdnC3gV74iInLlDlsJ7CgL-jFQ_NCE7PlIUf0ai3jwlTYgaIJZ2QJ_zyKLzUll7adSQqglKzv_aWOXK6Irdyf__rBdZCQSvdiGQUCA7-xKy3XAH5eF2a9VgMwhqYCiFbzy7gBoPvVXV1mjfM0_J48Y82K-Ic6OP2GyEgZ2T7onqkaFl2Q');">
                <div class="absolute inset-0 bg-gradient-to-b from-background-dark/70 via-background-dark/50 to-background-dark/95"></div>
                <div class="relative z-10 flex flex-col items-center gap-6 max-w-3xl mx-auto text-center px-6">
                    <span class="text-primary text-xs font-bold tracking-[0.4em] uppercase">Consignaciones</span>
                    <h2 class="font-serif text-slate-50 text-4xl md:text-5xl lg:text-6xl font-black leading-tight tracking-wide drop-shadow-xl">
                        Vendé tu instrumento
                    </h2>
                    <p class="text-slate-300 text-lg md:text-xl font-light tracking-wide max-w-xl">
                        Dejalo en nuestras manos. Nosotros nos encargamos de encontrarle un nuevo dueño.
                    </p>
                    <div class="flex flex-wrap gap-4 justify-center mt-4">
                        <a href="/consignaciones"
                            class="min-w-[180px] h-14 flex items-center justify-center rounded-sm bg-primary text-background-dark text-sm font-bold tracking-widest uppercase hover:bg-primary/90 transition-all border border-primary shadow-lg shadow-primary/20 px-8">
                            Vender mi instrumento
                        </a>
                        <a href="/consignaciones"
                            class="min-w-[180px] h-14 flex items-center justify-center rounded-sm bg-transparent text-primary text-sm font-bold tracking-widest uppercase hover:bg-primary/10 transition-all border border-primary px-8">
                            Lee Más
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Arrows -->
        <button id="carousel-prev" aria-label="Diapositiva anterior" class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 md:w-14 md:h-14 rounded-full bg-background-dark/50 border border-primary/30 backdrop-blur-sm flex items-center justify-center text-primary hover:bg-primary hover:text-background-dark transition-all duration-300 group">
            <span class="material-symbols-outlined text-2xl group-hover:scale-110 transition-transform">chevron_left</span>
        </button>
        <button id="carousel-next" aria-label="Siguiente diapositiva" class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 md:w-14 md:h-14 rounded-full bg-background-dark/50 border border-primary/30 backdrop-blur-sm flex items-center justify-center text-primary hover:bg-primary hover:text-background-dark transition-all duration-300 group">
            <span class="material-symbols-outlined text-2xl group-hover:scale-110 transition-transform">chevron_right</span>
        </button>

        <!-- Dot Indicators -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex gap-3" id="carousel-dots">
            <button class="carousel-dot w-3 h-3 rounded-full bg-primary transition-all duration-300 scale-100" data-index="0" aria-label="Ir a diapositiva 1"></button>
            <button class="carousel-dot w-3 h-3 rounded-full bg-slate-500 hover:bg-primary/60 transition-all duration-300 scale-75" data-index="1" aria-label="Ir a diapositiva 2"></button>
            <button class="carousel-dot w-3 h-3 rounded-full bg-slate-500 hover:bg-primary/60 transition-all duration-300 scale-75" data-index="2" aria-label="Ir a diapositiva 3"></button>
        </div>

        <!-- Progress Bar -->
        <div class="absolute bottom-0 left-0 right-0 z-20 h-[3px] bg-primary/10">
            <div id="carousel-progress" class="h-full bg-primary transition-all" style="width: 0%"></div>
        </div>
    </div>

    <!-- Featured Products Showcase -->
    {featuredProducts.length > 0 && (
    <section id="featured-products" aria-labelledby="featured-heading" class="py-12 px-4 max-w-7xl mx-auto w-full">
        <div class="flex flex-col sm:flex-row items-center justify-between mb-10 border-b border-primary/20 pb-4">
            <h2 id="featured-heading" class="font-serif text-3xl font-black tracking-wide text-slate-900 dark:text-slate-50 border-l-4 border-primary pl-4">
                Colección Destacada
            </h2>
            <a href="/categoria/electricas" class="text-sm font-bold text-primary hover:text-primary/80 uppercase tracking-widest flex items-center gap-2 mt-4 sm:mt-0 transition-colors">
                Ver Catálogo <span class="material-symbols-outlined text-lg">arrow_forward</span>
            </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {featuredProducts.map(product => (
                <ProductCard product={product} />
            ))}
        </div>
    </section>
    )}

    <!-- Categories -->
    <section id="categories" aria-labelledby="categories-heading" class="py-12 px-4 max-w-7xl mx-auto w-full">
        <div class="flex items-center justify-between mb-8 border-b border-primary/20 pb-4">
            <h2 id="categories-heading"
                class="font-serif text-2xl font-bold tracking-wide text-slate-900 dark:text-slate-50 border-l-4 border-primary pl-4">
                Categorías
            </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <a class="group relative flex flex-col gap-3 rounded-sm overflow-hidden aspect-[16/9] border border-primary/20 shadow-lg hover:border-primary/50 transition-colors"
                href="/categoria/electricas"
                style="background-image: url('/CoverHero.jpeg'); background-size: cover; background-position: center;">
                <div
                    class="absolute inset-0 bg-gradient-to-t from-background-dark/95 via-background-dark/40 to-transparent group-hover:from-background-dark transition-all duration-300">
                </div>
                <div class="relative z-10 h-full flex flex-col justify-end p-8">
                    <p class="font-serif text-primary text-3xl font-black leading-tight tracking-wide drop-shadow-md">
                        Guitarras Eléctricas</p>
                    <span
                        class="text-xs text-slate-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity tracking-widest uppercase font-bold">
                        Explorar Colección &rarr;
                    </span>
                </div>
            </a>
            <a class="group relative flex flex-col gap-3 rounded-sm overflow-hidden aspect-[16/9] border border-primary/20 shadow-lg hover:border-primary/50 transition-colors"
                href="/categoria/acusticas"
                style="background-image: url('/acustica.jpg'); background-size: cover; background-position: center;">
                <div
                    class="absolute inset-0 bg-gradient-to-t from-background-dark/95 via-background-dark/40 to-transparent group-hover:from-background-dark transition-all duration-300">
                </div>
                <div class="relative z-10 h-full flex flex-col justify-end p-8">
                    <p class="font-serif text-primary text-3xl font-black leading-tight tracking-wide drop-shadow-md">
                        Guitarras Acústicas</p>
                    <span
                        class="text-xs text-slate-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity tracking-widest uppercase font-bold">
                        Explorar Colección &rarr;
                    </span>
                </div>
            </a>
            <a class="group relative flex flex-col gap-3 rounded-sm overflow-hidden aspect-[16/9] border border-primary/20 shadow-lg hover:border-primary/50 transition-colors"
                href="/categoria/bajos"
                style="background-image: url('/bass.jpg'); background-size: cover; background-position: center;">
                <div
                    class="absolute inset-0 bg-gradient-to-t from-background-dark/95 via-background-dark/40 to-transparent group-hover:from-background-dark transition-all duration-300">
                </div>
                <div class="relative z-10 h-full flex flex-col justify-end p-8">
                    <p class="font-serif text-primary text-3xl font-black leading-tight tracking-wide drop-shadow-md">
                        Bajos</p>
                    <span
                        class="text-xs text-slate-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity tracking-widest uppercase font-bold">
                        Explorar Colección &rarr;
                    </span>
                </div>
            </a>
            <a class="group relative flex flex-col gap-3 rounded-sm overflow-hidden aspect-[16/9] border border-primary/20 shadow-lg hover:border-primary/50 transition-colors"
                href="/categoria/amplificadores"
                style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCmqNj2JacPW8EE_E-qKLVFd2oP4mfJq3VmIYFjYW8L2xM0BYsJYVLtClXCx7BWyoXWXnLALONLW-LJclLLCktwER8S4YDdnC3gV74iInLlDlsJ7CgL-jFQ_NCE7PlIUf0ai3jwlTYgaIJZ2QJ_zyKLzUll7adSQqglKzv_aWOXK6Irdyf__rBdZCQSvdiGQUCA7-xKy3XAH5eF2a9VgMwhqYCiFbzy7gBoPvVXV1mjfM0_J48Y82K-Ic6OP2GyEgZ2T7onqkaFl2Q'); background-size: cover; background-position: center;">
                <div
                    class="absolute inset-0 bg-gradient-to-t from-background-dark/95 via-background-dark/40 to-transparent group-hover:from-background-dark transition-all duration-300">
                </div>
                <div class="relative z-10 h-full flex flex-col justify-end p-8">
                    <p class="font-serif text-primary text-3xl font-black leading-tight tracking-wide drop-shadow-md">
                        Amplificadores</p>
                    <span
                        class="text-xs text-slate-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity tracking-widest uppercase font-bold">
                        Explorar Colección &rarr;
                    </span>
                </div>
            </a>
            <a class="group relative flex flex-col gap-3 rounded-sm overflow-hidden aspect-[16/9] border border-primary/20 shadow-lg hover:border-primary/50 transition-colors"
                href="/categoria/efectos"
                style="background-image: url('/pedals.jpg'); background-size: cover; background-position: center;">
                <div
                    class="absolute inset-0 bg-gradient-to-t from-background-dark/95 via-background-dark/40 to-transparent group-hover:from-background-dark transition-all duration-300">
                </div>
                <div class="relative z-10 h-full flex flex-col justify-end p-8">
                    <p class="font-serif text-primary text-3xl font-black leading-tight tracking-wide drop-shadow-md">
                        Efectos</p>
                    <span
                        class="text-xs text-slate-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity tracking-widest uppercase font-bold">
                        Explorar Colección &rarr;
                    </span>
                </div>
            </a>
        </div>
    </section>
</BaseLayout>

<script>
    // Use a global reference for cleanup
    let _carouselTimer: ReturnType<typeof setInterval> | null = null;
    let _carouselAbortController: AbortController | null = null;

    function initCarousel() {
        // Clear any existing timer first
        if (_carouselTimer) {
            clearInterval(_carouselTimer);
            _carouselTimer = null;
        }

        // Abort any existing listeners first
        if (_carouselAbortController) {
            _carouselAbortController.abort();
        }
        _carouselAbortController = new AbortController();
        const { signal } = _carouselAbortController;

        const track = document.getElementById('carousel-track') as HTMLElement;
        const dots = Array.from(document.querySelectorAll<HTMLElement>('.carousel-dot'));
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const progressBar = document.getElementById('carousel-progress') as HTMLElement;

        if (!track || dots.length === 0) return;

        const totalSlides = dots.length;
        let currentSlide = 0;
        const SLIDE_DURATION = 6000;

        function goToSlide(index: number) {
            currentSlide = ((index % totalSlides) + totalSlides) % totalSlides;
            track.style.transform = `translateX(-${currentSlide * 100}%)`;
            
            dots.forEach((dot, i) => {
                if (i === currentSlide) {
                    dot.classList.remove('bg-slate-500', 'scale-75');
                    dot.classList.add('bg-primary', 'scale-100');
                } else {
                    dot.classList.remove('bg-primary', 'scale-100');
                    dot.classList.add('bg-slate-500', 'scale-75');
                }
            });

            resetProgress();
        }

        function nextSlide() {
            goToSlide(currentSlide + 1);
        }

        function prevSlide() {
            goToSlide(currentSlide - 1);
        }

        function resetProgress() {
            if (progressBar) {
                progressBar.style.transition = 'none';
                progressBar.style.width = '0%';
                void progressBar.offsetHeight; // force reflow
                progressBar.style.transition = `width ${SLIDE_DURATION}ms linear`;
                progressBar.style.width = '100%';
            }
        }

        function startAutoPlay() {
            stopAutoPlay();
            resetProgress();
            _carouselTimer = setInterval(nextSlide, SLIDE_DURATION);
        }

        function stopAutoPlay() {
            if (_carouselTimer) {
                clearInterval(_carouselTimer);
                _carouselTimer = null;
            }
        }

        prevBtn?.addEventListener('click', () => { prevSlide(); startAutoPlay(); }, { signal });
        nextBtn?.addEventListener('click', () => { nextSlide(); startAutoPlay(); }, { signal });

        dots.forEach(dot => {
            dot.addEventListener('click', () => {
                const index = parseInt(dot.getAttribute('data-index') || '0');
                goToSlide(index);
                startAutoPlay();
            }, { signal });
        });

        // Touch/swipe
        let touchStartX = 0;
        track.addEventListener('touchstart', (e) => {
            touchStartX = e.changedTouches[0].screenX;
            stopAutoPlay();
        }, { passive: true, signal });

        track.addEventListener('touchend', (e) => {
            const diff = touchStartX - e.changedTouches[0].screenX;
            if (Math.abs(diff) > 50) {
                if (diff > 0) nextSlide(); else prevSlide();
            }
            startAutoPlay();
        }, { passive: true, signal });

        // Pause on hover
        const carousel = document.getElementById('hero-carousel');
        carousel?.addEventListener('mouseenter', stopAutoPlay, { signal });
        carousel?.addEventListener('mouseleave', startAutoPlay, { signal });

        // Pause when tab is hidden
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) stopAutoPlay();
            else startAutoPlay();
        }, { signal });

        // Start!
        startAutoPlay();
    }

    initCarousel();
    document.addEventListener('astro:page-load', initCarousel);
</script>
