---
export const prerender = false;
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import { getCategoryBySlug, getProducts } from '../../lib/queries';

const { slug } = Astro.params;
const category = await getCategoryBySlug(slug as string);

if (!category) {
  return new Response("Not Found", { status: 404 });
}

const products = await getProducts({ categoryId: category.id });
const pageTitle = `${category.name} | El Garaje de las Guitarras`;

// Split brands: available (shown by default) vs sold-only (shown when toggle opens)
const availableProducts = products.filter(p => p.status !== 'vendido');
const soldProducts = products.filter(p => p.status === 'vendido');

const availableBrands = [...new Set(availableProducts.map(p => p.brand || 'Otras'))].sort();
const soldOnlyBrands = [...new Set(soldProducts.map(p => p.brand || 'Otras'))]
    .filter(b => !availableBrands.includes(b))
    .sort();
---

<CategoryLayout 
    title={pageTitle} 
    description={category.seo_description || category.description || ''}
    categoryName={category.name}
    categoryDescription={category.description}
    brands={availableBrands}
    soldOnlyBrands={soldOnlyBrands}
>
    {products.length > 0 ? (
        products.map(product => (
            <ProductCard product={product} />
        ))
    ) : (
        <div class="col-span-full py-12 text-center text-slate-400">
            <p>No hay productos disponibles en esta categoría actualmente.</p>
        </div>
    )}
</CategoryLayout>
