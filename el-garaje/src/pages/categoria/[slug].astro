---
export const prerender = false;
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import { getCategoryPage } from '../../application/category/get-category-page';

const { slug } = Astro.params;
const result = await getCategoryPage(slug as string);

if (!result) {
  return new Response("Not Found", { status: 404 });
}

const { category, products } = result;
const pageTitle = `${category.name} | El Garaje de las Guitarras`;

// Split brands: available vs sold-only
const availableBrands = [...new Set(products.filter(p => !p.isSold).map(p => p.brand || 'Otras'))].sort();
const soldOnlyBrands = [...new Set(products.filter(p => p.isSold).map(p => p.brand || 'Otras'))]
    .filter(b => !availableBrands.includes(b))
    .sort();
---

<CategoryLayout 
    title={pageTitle} 
    description={category.seoDescription || category.description || ''}
    categoryName={category.name}
    categoryDescription={category.description}
    brands={availableBrands}
    soldOnlyBrands={soldOnlyBrands}
>
    {products.length > 0 ? (
        products.map(product => (
            <ProductCard product={product} />
        ))
    ) : (
        <div class="col-span-full py-12 text-center text-slate-400">
            <p>No hay productos disponibles en esta categoría actualmente.</p>
        </div>
    )}
</CategoryLayout>
