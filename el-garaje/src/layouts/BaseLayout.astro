---
import '../styles/global.css';
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingContactButtons from '../components/layout/FloatingContactButtons.astro';
import AmbientMusic from '../components/layout/AmbientMusic.astro';
import SearchModal from '../components/layout/SearchModal.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import UpdateNotification from '../components/layout/UpdateNotification.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <BaseHead title={title} description={description} />
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display selection:bg-primary/30 min-h-screen">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden @container pb-20">
        <Header />
        <MobileMenu />
        
        <main class="flex-1">
            <slot />
        </main>

        <Footer />
    </div>

    <FloatingContactButtons />
    <AmbientMusic />
    <SearchModal />
    <CartDrawer />
    <UpdateNotification />

    <!-- Agent Border Glow Overlay -->
    <div class="agent-border-glow" id="agent-glow" transition:persist="agent-glow"></div>

    <script>
        // ============================================================
        // REACTIVE AGENT UI — Trigger System
        // ============================================================

        function initAgentUI() {
            const glow = document.getElementById('agent-glow')!;

            let glowTimeout: ReturnType<typeof setTimeout> | null = null;

            function fireGlow(duration = 800) {
                if (glowTimeout) clearTimeout(glowTimeout);
                glow.classList.add('active');
                glowTimeout = setTimeout(() => {
                    glow.classList.remove('active');
                    glowTimeout = null;
                }, duration);
            }

            // --- Expose globally so other components can trigger it ---
            (window as any).__fireAgentGlow = fireGlow;

            // --- Trigger: Brand filter clicks ---
            const brandFilters = document.getElementById('brand-filters');
            if (brandFilters) {
                brandFilters.addEventListener('click', (e) => {
                    if ((e.target as HTMLElement).closest('.brand-btn')) {
                        fireGlow(600);
                    }
                });
            }

            // --- Trigger: Category navigation (View Transition start) ---
            document.addEventListener('astro:before-swap', () => fireGlow(800));

            // --- Trigger: Product image gallery clicks ---
            document.querySelectorAll('[data-gallery-thumb], [data-gallery-image]').forEach(el => {
                el.addEventListener('click', () => fireGlow(500));
            });

            // --- Trigger: Product card clicks ---
            const productGrid = document.getElementById('product-grid');
            if (productGrid) {
                productGrid.addEventListener('click', (e) => {
                    if ((e.target as HTMLElement).closest('[data-brand]')) {
                        fireGlow(500);
                    }
                });
            }

            // --- Behavioral Trigger: IntersectionObserver on product CTA zone ---
            const productFooter = document.querySelector('.product-footer');
            if (productFooter) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            // Fire glow + WhatsApp pulse simultaneously
                            fireGlow(1500);
                            (window as any).__fireWhatsAppPulse?.();
                            observer.unobserve(entry.target); // Only once per page
                        }
                    });
                }, { threshold: 0.5 });
                observer.observe(productFooter);
            }
        }

        // Ensure it works with View Transitions
        document.addEventListener('astro:page-load', initAgentUI);

        // Search is now handled by SearchModal component
    </script>
</body>
</html>
