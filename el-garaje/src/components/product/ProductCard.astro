---
import type { Product } from '../../domain/product/product.types';
import StatusBadge from './StatusBadge.astro';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageUrl = (product.images && product.images.length > 0) ? product.images[0] : '/logo.avif';
const ariaLabel = `${product.title}. ${product.isSold ? 'Vendido.' : `Precio: ${product.priceLabel}`}`;
---

<a href={`/producto/${product.slug}`}
    aria-label={ariaLabel}
    data-brand={product.brand || 'Otras'}
    data-status={product.status}
    class="group flex flex-col bg-accent-dark/20 border border-primary/10 hover:border-primary/50 transition-all duration-300 rounded-sm overflow-hidden">
    
    <div class="aspect-square bg-gradient-to-br from-slate-800 to-slate-900 relative overflow-hidden flex items-center justify-center p-8">
        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent z-10"></div>
        <img 
            src={imageUrl}
            alt={product.title}
            loading="lazy"
            decoding="async"
            class={`object-cover h-full w-full transition-all duration-500 image-blur-up ${product.isSold ? 'opacity-50 grayscale-[30%]' : 'opacity-0 group-hover:opacity-100'}`} />
            
        <div class="absolute top-4 left-4 z-20">
            <StatusBadge status={product.status} badge={product.badge} />
        </div>

        {product.isSold && (
            <div class="sold-ribbon">VENDIDO</div>
        )}
    </div>
    
    <div class="p-5 flex flex-col grow">
        <h2 class="font-serif text-xl font-bold text-slate-200 group-hover:text-primary transition-colors line-clamp-2">
            {product.title}
        </h2>
        <p class="text-slate-400 text-sm mt-2 mb-4">{product.shortDescription || ''}</p>
        
        <div class={`mt-auto border-t border-primary/10 pt-4 flex justify-between items-center ${product.isSold ? 'opacity-50' : ''}`}>
            {!product.isSold ? (
                <>
                   <span class="font-serif text-lg text-primary tracking-wide">{product.priceLabel}</span>
                   <span class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </>
            ) : (
                <span class="font-serif text-lg text-slate-400 tracking-wide line-through">{product.priceLabel}</span>
            )}
        </div>
    </div>
</a>

<style>
    .image-blur-up {
        filter: blur(20px);
        transform: scale(1.1);
    }
    
    .image-blur-up.loaded,
    .group:hover .image-blur-up {
        filter: blur(0);
        transform: scale(1);
        opacity: 1;
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('.image-blur-up').forEach((img) => {
            if (img instanceof HTMLImageElement) {
                if (img.complete) {
                    img.classList.add('loaded');
                } else {
                    img.addEventListener('load', () => img.classList.add('loaded'));
                }
            }
        });
    });
</script>
