---
import type { Product } from '../../lib/types';
import StatusBadge from './StatusBadge.astro';
import { getPublicImageUrl } from '../../lib/image-utils';

interface Props {
  product: Product;
}

const { product } = Astro.props;

// Format Price — always show value, never "Consultar"
const priceDisplay = product.price_display || (product.price ? `U$D ${product.price.toLocaleString()}` : 'U$D 9.999.999,99');

// Get cover image (the one with the lowest sort order)
const coverImage = product.product_images && product.product_images.length > 0
    ? product.product_images.sort((a, b) => a.sort_order - b.sort_order)[0]
    : null;

const imageUrl = coverImage 
    ? getPublicImageUrl(coverImage.storage_path)
    // Fallback placeholder
    : 'https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=600&auto=format&fit=crop';

const isSold = product.status === 'vendido';
---

<a href={`/producto/${product.slug}`}
    data-brand={product.brand || 'Otras'}
    data-status={product.status}
    class="group flex flex-col bg-accent-dark/20 border border-primary/10 hover:border-primary/50 transition-all duration-300 rounded-sm overflow-hidden">
    
    <div class="aspect-square bg-black relative overflow-hidden flex items-center justify-center p-8">
        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent z-10"></div>
        <img src={imageUrl}
            alt={coverImage?.alt_text || product.title}
            loading="lazy"
            class={`object-cover h-full w-full group-hover:scale-105 transition-transform duration-700 ${isSold ? 'opacity-50 grayscale-[30%]' : 'opacity-80 group-hover:opacity-100'}`} />
            
        <div class="absolute top-4 left-4 z-20">
            <StatusBadge status={product.status} badge={product.badge} />
        </div>

        {/* VENDIDO diagonal ribbon */}
        {isSold && (
            <div class="sold-ribbon">VENDIDO</div>
        )}
    </div>
    
    <div class="p-5 flex flex-col grow">
        <h2 class="font-serif text-xl font-bold text-slate-200 group-hover:text-primary transition-colors line-clamp-2">
            {product.title}
        </h2>
        <p class="text-slate-500 text-sm mt-2 mb-4">{product.short_description || ''}</p>
        
        <div class={`mt-auto border-t border-primary/10 pt-4 flex justify-between items-center ${isSold ? 'opacity-50' : ''}`}>
            {!isSold ? (
                <>
                   <span class="font-serif text-lg text-primary tracking-wide">{priceDisplay}</span>
                   <span class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </>
            ) : (
                <span class="font-serif text-lg text-slate-400 tracking-wide line-through">{priceDisplay}</span>
            )}
        </div>
    </div>
</a>
