---
import type { Product } from '../../domain/product/product.types';

interface Props {
  product: Product;
}

const { product } = Astro.props;

interface SpecRow {
    label: string;
    value: string;
}

const finalSpecs: SpecRow[] = [];

if (product.brand) finalSpecs.push({ label: 'Marca', value: product.brand });
if (product.year) finalSpecs.push({ label: 'Año', value: product.year.toString() });

if (product.specifications && Array.isArray(product.specifications)) {
    product.specifications.forEach(spec => {
        // Handle both {label, value} and {key: value} formats
        if (spec.label && spec.value) {
            finalSpecs.push({ label: spec.label, value: spec.value });
        } else {
            const keys = Object.keys(spec);
            if (keys.length > 0 && keys[0] !== 'label' && keys[0] !== 'value') {
                finalSpecs.push({ label: keys[0], value: String(spec[keys[0]]) });
            }
        }
    });
}
---

<div class="flex flex-col gap-4">
    <h3 class="font-serif text-2xl font-bold text-slate-200 mb-2 border-b border-primary/20 pb-4">
        Especificaciones
    </h3>

    {finalSpecs.length > 0 ? (
        finalSpecs.map(spec => (
            <div class="grid grid-cols-3 py-4 border-b border-white/5">
                <div class="col-span-1 text-slate-400 font-bold text-xs uppercase tracking-widest">{spec.label}</div>
                <div class="col-span-2 text-slate-300">{spec.value}</div>
            </div>
        ))
    ) : (
        <p class="text-slate-400 italic py-4">No hay especificaciones detalladas para este instrumento.</p>
    )}
</div>
