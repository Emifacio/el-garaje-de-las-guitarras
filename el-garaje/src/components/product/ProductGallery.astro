---
import type { ProductImage } from '../../lib/types';
import { getPublicImageUrl } from '../../lib/image-utils';

interface Props {
  images: ProductImage[] | null;
  title: string;
  isSold?: boolean;
}

const { images, title, isSold = false } = Astro.props;

// Sort images and map to public URLs
const sortedImages = images 
    ? [...images].sort((a, b) => a.sort_order - b.sort_order) 
    : [];

const imageUrls = sortedImages.map(img => getPublicImageUrl(img.storage_path));

let mainImage = imageUrls.length > 0 
    ? imageUrls[0] 
    : '/logo.avif';
---

<div class="flex flex-col gap-4" id="product-gallery" data-images={JSON.stringify(imageUrls)}>
    <!-- Main Image with Lens Zoom -->
    <div id="gallery-main-wrap"
         class="aspect-square bg-accent-dark/20 border border-primary/20 rounded-sm overflow-hidden relative group cursor-crosshair">
        <img 
            id="gallery-main-image"
            src={mainImage}
            alt={title}
            class={`object-cover h-full w-full transition-opacity duration-300 ${isSold ? 'opacity-50 grayscale-[30%]' : 'opacity-90'}`}
        />
        <!-- Zoom Lens (desktop hover) -->
        <div id="gallery-lens"
             class="hidden lg:block pointer-events-none absolute w-[140px] h-[140px] rounded-full border-2 border-primary/60 shadow-lg shadow-primary/10 opacity-0 transition-opacity duration-150 z-10"
             style="background-repeat:no-repeat;">
        </div>
        <!-- Zoom Result (desktop hover) -->
        <div id="gallery-zoom-result"
             class="hidden lg:block pointer-events-none absolute top-0 right-0 translate-x-[calc(100%+16px)] w-[360px] h-[360px] rounded-sm border border-primary/30 bg-background-dark shadow-2xl shadow-black/50 opacity-0 transition-opacity duration-200 z-30 overflow-hidden"
             style="background-repeat:no-repeat;">
        </div>
        <!-- Click hint -->
        <div class="absolute bottom-3 right-3 z-10 flex items-center gap-1.5 bg-background-dark/70 backdrop-blur-sm text-slate-300 text-xs px-3 py-1.5 rounded-full border border-primary/20 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
            <span class="material-symbols-outlined text-sm text-primary">zoom_in</span>
            Click para ampliar
        </div>
        {isSold && (
            <div class="sold-ribbon sold-ribbon--large">VENDIDO</div>
        )}
    </div>

    <!-- Thumbnails -->
    {imageUrls.length > 1 && (
        <div class="grid grid-cols-4 gap-4" id="gallery-thumbnails">
            {imageUrls.map((url, index) => (
                <button
                    type="button"
                    class={`gallery-thumb aspect-square bg-black border ${index === 0 ? 'border-primary opacity-100' : 'border-primary/20 opacity-60'} rounded-sm overflow-hidden hover:opacity-100 transition-all`}
                    data-src={url}
                    data-index={index}
                >
                    <img 
                        src={url}
                        alt={`${title} - Vista ${index + 1}`}
                        class="object-cover h-full w-full opacity-70" 
                    />
                </button>
            ))}
        </div>
    )}
</div>

<!-- Lightbox Overlay -->
<div id="gallery-lightbox"
     class="fixed inset-0 z-[200] bg-black/95 backdrop-blur-md hidden opacity-0 transition-opacity duration-300"
     role="dialog" aria-modal="true" aria-label="Galería de imágenes">
    <!-- Close -->
    <button id="lightbox-close" aria-label="Cerrar galería"
            class="absolute top-4 right-4 z-50 w-12 h-12 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white hover:bg-primary hover:text-background-dark hover:border-primary transition-all">
        <span class="material-symbols-outlined text-2xl">close</span>
    </button>

    <!-- Counter -->
    <div id="lightbox-counter"
         class="absolute top-5 left-1/2 -translate-x-1/2 z-50 text-slate-400 text-sm font-bold tracking-widest">
    </div>

    <!-- Prev / Next -->
    <button id="lightbox-prev" aria-label="Imagen anterior"
            class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 z-50 w-12 h-12 md:w-14 md:h-14 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white hover:bg-primary hover:text-background-dark hover:border-primary transition-all">
        <span class="material-symbols-outlined text-2xl">chevron_left</span>
    </button>
    <button id="lightbox-next" aria-label="Siguiente imagen"
            class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 z-50 w-12 h-12 md:w-14 md:h-14 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white hover:bg-primary hover:text-background-dark hover:border-primary transition-all">
        <span class="material-symbols-outlined text-2xl">chevron_right</span>
    </button>

    <!-- Main Image Container (pinch-to-zoom on mobile) -->
    <div id="lightbox-image-wrap"
         class="absolute inset-0 flex items-center justify-center p-4 md:p-16 pt-16 pb-28 touch-none">
        <img id="lightbox-image"
             src=""
             alt=""
             class="max-w-full max-h-full object-contain select-none transition-transform duration-200 ease-out"
             draggable="false" />
    </div>

    <!-- Thumbnail Strip -->
    <div id="lightbox-thumbs"
         class="absolute bottom-0 left-0 right-0 z-50 flex justify-center gap-2 p-4 bg-gradient-to-t from-black/80 to-transparent overflow-x-auto">
    </div>
</div>

<script>
    function setupProductGallery() {
        const gallery = document.getElementById('product-gallery');
        const mainImg = document.getElementById('gallery-main-image') as HTMLImageElement;
        const mainWrap = document.getElementById('gallery-main-wrap');
        const thumbnails = Array.from(document.querySelectorAll<HTMLElement>('.gallery-thumb'));
        const lens = document.getElementById('gallery-lens');
        const zoomResult = document.getElementById('gallery-zoom-result');

        if (!gallery || !mainImg) return;

        const allUrls: string[] = JSON.parse(gallery.getAttribute('data-images') || '[]');
        let currentIndex = 0;

        // ─── Thumbnail clicks ───
        thumbnails.forEach(thumb => {
            thumb.addEventListener('click', () => {
                const newSrc = thumb.getAttribute('data-src');
                const idx = parseInt(thumb.getAttribute('data-index') || '0');
                if (newSrc) {
                    mainImg.src = newSrc;
                    currentIndex = idx;
                    highlightThumb(idx);
                }
            });
        });

        function highlightThumb(idx: number) {
            thumbnails.forEach((t, i) => {
                if (i === idx) {
                    t.classList.remove('border-primary/20', 'opacity-60');
                    t.classList.add('border-primary', 'opacity-100');
                } else {
                    t.classList.remove('border-primary', 'opacity-100');
                    t.classList.add('border-primary/20', 'opacity-60');
                }
            });
        }

        // ─── Lens Zoom (desktop only) ───
        if (mainWrap && lens && zoomResult) {
            const ZOOM = 2.5;

            mainWrap.addEventListener('mouseenter', () => {
                lens.style.opacity = '1';
                zoomResult.style.opacity = '1';
                zoomResult.style.backgroundImage = `url('${mainImg.src}')`;
            });

            mainWrap.addEventListener('mouseleave', () => {
                lens.style.opacity = '0';
                zoomResult.style.opacity = '0';
            });

            mainWrap.addEventListener('mousemove', (e) => {
                const rect = mainWrap.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                // Position lens
                const lensW = lens.offsetWidth / 2;
                const lensH = lens.offsetHeight / 2;
                lens.style.left = `${Math.max(lensW, Math.min(rect.width - lensW, x)) - lensW}px`;
                lens.style.top = `${Math.max(lensH, Math.min(rect.height - lensH, y)) - lensH}px`;
                lens.style.backgroundImage = `url('${mainImg.src}')`;
                lens.style.backgroundSize = `${rect.width * ZOOM}px ${rect.height * ZOOM}px`;
                const lensX = x * ZOOM - lensW;
                const lensY = y * ZOOM - lensH;
                lens.style.backgroundPosition = `-${lensX}px -${lensY}px`;

                // Position zoom result
                const ratioX = x / rect.width;
                const ratioY = y / rect.height;
                const resultW = zoomResult.offsetWidth;
                const resultH = zoomResult.offsetHeight;
                const bgW = rect.width * ZOOM;
                const bgH = rect.height * ZOOM;
                zoomResult.style.backgroundSize = `${bgW}px ${bgH}px`;
                zoomResult.style.backgroundPosition = `-${ratioX * bgW - resultW / 2}px -${ratioY * bgH - resultH / 2}px`;
            });
        }

        // ─── Lightbox ───
        const lightbox = document.getElementById('gallery-lightbox')!;
        const lbImage = document.getElementById('lightbox-image') as HTMLImageElement;
        const lbClose = document.getElementById('lightbox-close');
        const lbPrev = document.getElementById('lightbox-prev');
        const lbNext = document.getElementById('lightbox-next');
        const lbCounter = document.getElementById('lightbox-counter');
        const lbThumbs = document.getElementById('lightbox-thumbs');
        const lbImageWrap = document.getElementById('lightbox-image-wrap');

        if (!lbImage || allUrls.length === 0) return;

        let lbIndex = 0;

        function openLightbox(startIndex: number) {
            lbIndex = startIndex;
            updateLightbox();
            buildLightboxThumbs();
            lightbox.classList.remove('hidden');
            requestAnimationFrame(() => {
                lightbox.classList.remove('opacity-0');
                lightbox.classList.add('opacity-100');
            });
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            lightbox.classList.remove('opacity-100');
            lightbox.classList.add('opacity-0');
            setTimeout(() => lightbox.classList.add('hidden'), 300);
            document.body.style.overflow = '';
            resetPinchZoom();
        }

        function updateLightbox() {
            lbIndex = ((lbIndex % allUrls.length) + allUrls.length) % allUrls.length;
            lbImage.src = allUrls[lbIndex];
            if (lbCounter) lbCounter.textContent = `${lbIndex + 1} / ${allUrls.length}`;
            resetPinchZoom();

            // Highlight active thumb in lightbox
            lbThumbs?.querySelectorAll('button').forEach((btn, i) => {
                if (i === lbIndex) {
                    btn.classList.remove('opacity-40', 'border-transparent');
                    btn.classList.add('opacity-100', 'border-primary');
                } else {
                    btn.classList.remove('opacity-100', 'border-primary');
                    btn.classList.add('opacity-40', 'border-transparent');
                }
            });

            // Also sync page gallery
            mainImg.src = allUrls[lbIndex];
            currentIndex = lbIndex;
            highlightThumb(lbIndex);
        }

        function buildLightboxThumbs() {
            if (!lbThumbs) return;
            lbThumbs.innerHTML = '';
            allUrls.forEach((url, i) => {
                const btn = document.createElement('button');
                btn.className = `w-14 h-14 md:w-16 md:h-16 rounded-sm overflow-hidden border-2 flex-shrink-0 transition-all ${i === lbIndex ? 'opacity-100 border-primary' : 'opacity-40 border-transparent'} hover:opacity-80`;
                btn.innerHTML = `<img src="${url}" alt="Vista ${i + 1}" class="w-full h-full object-cover" />`;
                btn.addEventListener('click', () => { lbIndex = i; updateLightbox(); });
                lbThumbs.appendChild(btn);
            });
        }

        // Open on main image click
        mainWrap?.addEventListener('click', (e) => {
            if ((e.target as HTMLElement).closest('#gallery-lens, #gallery-zoom-result')) return;
            openLightbox(currentIndex);
        });

        // Navigation
        lbClose?.addEventListener('click', closeLightbox);
        lbPrev?.addEventListener('click', () => { lbIndex--; updateLightbox(); });
        lbNext?.addEventListener('click', () => { lbIndex++; updateLightbox(); });

        // Hide arrows if single image
        if (allUrls.length <= 1) {
            lbPrev?.classList.add('hidden');
            lbNext?.classList.add('hidden');
        }

        // Keyboard
        document.addEventListener('keydown', (e) => {
            if (lightbox.classList.contains('hidden')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') { lbIndex--; updateLightbox(); }
            if (e.key === 'ArrowRight') { lbIndex++; updateLightbox(); }
        });

        // Click backdrop to close
        lightbox.addEventListener('click', (e) => {
            if (e.target === lbImageWrap) closeLightbox();
        });

        // ─── Pinch-to-Zoom (mobile touch) ───
        let pinchScale = 1;
        let pinchStartDist = 0;
        let panStartX = 0;
        let panStartY = 0;
        let translateX = 0;
        let translateY = 0;
        let lastTranslateX = 0;
        let lastTranslateY = 0;
        let isPinching = false;

        function resetPinchZoom() {
            pinchScale = 1;
            translateX = 0;
            translateY = 0;
            lastTranslateX = 0;
            lastTranslateY = 0;
            lbImage.style.transform = '';
        }

        function applyTransform() {
            lbImage.style.transform = `translate(${translateX}px, ${translateY}px) scale(${pinchScale})`;
        }

        function getTouchDist(t1: Touch, t2: Touch) {
            return Math.hypot(t2.clientX - t1.clientX, t2.clientY - t1.clientY);
        }

        lbImageWrap?.addEventListener('touchstart', (e) => {
            if (e.touches.length === 2) {
                isPinching = true;
                pinchStartDist = getTouchDist(e.touches[0], e.touches[1]);
            } else if (e.touches.length === 1 && pinchScale > 1) {
                panStartX = e.touches[0].clientX - lastTranslateX;
                panStartY = e.touches[0].clientY - lastTranslateY;
            }
        }, { passive: true });

        lbImageWrap?.addEventListener('touchmove', (e) => {
            if (e.touches.length === 2 && isPinching) {
                const dist = getTouchDist(e.touches[0], e.touches[1]);
                const newScale = Math.max(1, Math.min(5, pinchScale * (dist / pinchStartDist)));
                pinchScale = newScale;
                pinchStartDist = dist;
                applyTransform();
            } else if (e.touches.length === 1 && pinchScale > 1) {
                translateX = e.touches[0].clientX - panStartX;
                translateY = e.touches[0].clientY - panStartY;
                applyTransform();
            }
        }, { passive: true });

        lbImageWrap?.addEventListener('touchend', (e) => {
            if (e.touches.length < 2) {
                isPinching = false;
                lastTranslateX = translateX;
                lastTranslateY = translateY;
            }
            if (e.touches.length === 0 && pinchScale <= 1) {
                resetPinchZoom();
            }
        }, { passive: true });

        // ─── Swipe in lightbox (single finger, no zoom) ───
        let swipeStartX = 0;
        lbImageWrap?.addEventListener('touchstart', (e) => {
            if (e.touches.length === 1 && pinchScale <= 1) {
                swipeStartX = e.touches[0].clientX;
            }
        }, { passive: true });

        lbImageWrap?.addEventListener('touchend', (e) => {
            if (e.changedTouches.length === 1 && pinchScale <= 1) {
                const diff = swipeStartX - e.changedTouches[0].clientX;
                if (Math.abs(diff) > 60) {
                    if (diff > 0) { lbIndex++; } else { lbIndex--; }
                    updateLightbox();
                }
            }
        }, { passive: true });

        // Double-tap to zoom/reset
        let lastTap = 0;
        lbImageWrap?.addEventListener('touchend', (e) => {
            if (e.changedTouches.length !== 1) return;
            const now = Date.now();
            if (now - lastTap < 300) {
                if (pinchScale > 1) {
                    resetPinchZoom();
                } else {
                    pinchScale = 2.5;
                    applyTransform();
                }
            }
            lastTap = now;
        }, { passive: true });
    }

    setupProductGallery();
    document.addEventListener('astro:page-load', setupProductGallery);
</script>
