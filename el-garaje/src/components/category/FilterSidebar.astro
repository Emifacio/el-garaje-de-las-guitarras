<aside class="w-full lg:w-64 shrink-0">
    <div class="sticky top-24 bg-accent-dark/30 p-6 border border-primary/10 rounded-sm">
        <h3 class="font-bold text-primary tracking-widest uppercase mb-6 text-sm">Filtrar Colección</h3>

        <!-- Brands Configuration (Static for now as per original design) -->
        <div class="mb-8">
            <h4 class="font-serif text-slate-300 mb-3 text-lg border-b border-primary/10 pb-2">Marcas</h4>
            <div class="flex flex-col gap-2">
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">Fender</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">Gibson</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">PRS</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">Otras</span>
                </label>
            </div>
        </div>

        <!-- Decades -->
        <div>
            <h4 class="font-serif text-slate-300 mb-3 text-lg border-b border-primary/10 pb-2">Décadas</h4>
            <div class="flex flex-col gap-2">
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">1950s</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">1960s</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                        class="rounded-sm border-primary/30 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" />
                    <span class="text-slate-400 group-hover:text-primary transition-colors">1970s</span>
                </label>
            </div>
        </div>
    </div>
</aside>
