---
---
<div id="mobile-menu" role="dialog" aria-modal="true" aria-hidden="true"
    transition:persist="mobile-menu"
    class="fixed inset-0 z-[60] bg-background-dark/98 transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden flex flex-col">
    <div class="flex justify-between items-center p-4 lg:p-6 border-b border-primary/10">
        <img src="/logo.jpg" alt="El Garaje de las Guitarras" class="h-10 w-auto object-contain" />
        <button id="btn-close-menu" aria-label="Close menu" class="text-slate-400 hover:text-primary">
            <span class="material-symbols-outlined text-3xl">close</span>
        </button>
    </div>
    <nav class="flex flex-col gap-6 p-8 overflow-y-auto" aria-label="Mobile navigation">
        <a href="/"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Home</a>
        <a href="/categoria/electricas"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Guitarras
            Eléctricas</a>
        <a href="/categoria/acusticas"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Guitarras
            Acústicas</a>
        <a href="/categoria/bajos"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Bajos</a>
        <a href="/categoria/amplificadores"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Amplificadores</a>
        <a href="/categoria/efectos"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Efectos</a>
        <a href="/afinador"
            class="text-2xl font-serif font-bold tracking-wide text-primary/80 hover:text-primary transition-colors">Afinador</a>
        <hr class="border-primary/20 my-2" />
        <a href="/consignaciones"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Consignaciones</a>
        <a href="/inspecciones"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Inspecciones</a>
        <a href="/sobre-elgaraje"
            class="text-2xl font-serif font-bold tracking-wide text-primary/80 hover:text-primary transition-colors">Nuestro Garaje</a>
        <a href="/contacto"
            class="text-2xl font-serif font-bold tracking-wide hover:text-primary transition-colors">Contacto</a>
    </nav>
</div>

<script>
    let cleanupMobileMenu: (() => void) | undefined;

    function initMobileMenu() {
        const menuBtn = document.getElementById('btn-menu');
        const mobileMenu = document.getElementById('mobile-menu');
        const closeMenuBtn = document.getElementById('btn-close-menu');

        if (!menuBtn || !mobileMenu || !closeMenuBtn) return;

        const openMenu = () => {
            mobileMenu.classList.remove('translate-x-full');
            mobileMenu.setAttribute('aria-hidden', 'false');
            menuBtn.setAttribute('aria-expanded', 'true');
        };

        const closeMenu = () => {
            mobileMenu.classList.add('translate-x-full');
            mobileMenu.setAttribute('aria-hidden', 'true');
            menuBtn.setAttribute('aria-expanded', 'false');
        };

        menuBtn.addEventListener('click', openMenu);
        closeMenuBtn.addEventListener('click', closeMenu);

        // Close menu when any nav link is clicked
        const navLinks = mobileMenu.querySelectorAll('nav a');
        navLinks.forEach(link => link.addEventListener('click', closeMenu));

        return () => {
            menuBtn.removeEventListener('click', openMenu);
            closeMenuBtn.removeEventListener('click', closeMenu);
            navLinks.forEach(link => link.removeEventListener('click', closeMenu));
        };
    }

    const runInit = () => {
        if (cleanupMobileMenu) cleanupMobileMenu();
        cleanupMobileMenu = initMobileMenu();
    };

    document.addEventListener('astro:page-load', runInit);
    document.addEventListener('astro:before-swap', () => {
        if (cleanupMobileMenu) cleanupMobileMenu();
        
        // Safety net: ensure menu is closed before swap
        const mobileMenu = document.getElementById('mobile-menu');
        const menuBtn = document.getElementById('btn-menu');
        if (mobileMenu) {
            mobileMenu.classList.add('translate-x-full');
            mobileMenu.setAttribute('aria-hidden', 'true');
        }
        if (menuBtn) {
            menuBtn.setAttribute('aria-expanded', 'false');
        }
    });
</script>
