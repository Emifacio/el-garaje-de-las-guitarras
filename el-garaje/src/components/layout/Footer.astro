<footer class="bg-background-dark border-t border-primary/20 pt-16 pb-8 px-4 mt-20">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
        <div class="md:col-span-1">
            <a class="block mb-6" href="/">
                <img src="/logo.jpg" alt="El Garaje de las Guitarras" class="h-24 w-auto object-contain drop-shadow-md" />
            </a>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
                Boutique especializada en la venta de instrumentos vintage premium.
            </p>
            <div class="flex gap-4">
                <a href="#" class="text-slate-400 hover:text-primary transition-colors">
                    <span class="font-bold text-lg">IG</span>
                </a>
                <a href="#" class="text-slate-400 hover:text-primary transition-colors">
                    <span class="font-bold text-lg">FB</span>
                </a>
                <a href="#" class="text-slate-400 hover:text-primary transition-colors">
                    <span class="font-bold text-lg">YT</span>
                </a>
            </div>
        </div>

        <div>
            <h4 class="font-serif text-lg text-slate-100 mb-6 font-bold tracking-wide">Catálogo</h4>
            <ul class="flex flex-col gap-4 text-sm text-slate-400">
                <li><a href="/categoria/electricas" class="hover:text-primary transition-colors">Guitarras Eléctricas</a></li>
                <li><a href="/categoria/acusticas" class="hover:text-primary transition-colors">Guitarras Acústicas</a></li>
                <li><a href="/categoria/bajos" class="hover:text-primary transition-colors">Bajos</a></li>
                <li><a href="/categoria/amplificadores" class="hover:text-primary transition-colors">Amplificadores</a></li>
            </ul>
        </div>

        <div>
            <h4 class="font-serif text-lg text-slate-100 mb-6 font-bold tracking-wide">Información</h4>
            <ul class="flex flex-col gap-4 text-sm text-slate-400">
                <li><a href="/sobre-elgaraje" class="hover:text-primary transition-colors">Sobre El Garaje</a></li>
                <li><a href="/sobre-elgaraje" class="hover:text-primary transition-colors">La Sala de Pruebas</a></li>
                <li><a href="#" class="hover:text-primary transition-colors">Instrumentos Vendidos</a></li>
                <li><a href="#" class="hover:text-primary transition-colors">Consignaciones</a></li>
            </ul>
        </div>

        <div>
            <h4 class="font-serif text-lg text-slate-100 mb-6 font-bold tracking-wide">Visitanos</h4>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">
                Para probar algún instrumento de nuestro catálogo, solicitanos una visita al bunker.
            </p>
            <a href="/contacto"
                class="inline-flex h-10 px-6 items-center justify-center rounded-sm bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase hover:bg-primary hover:text-background-dark transition-all border border-primary/50">
                Solicitar Visita
            </a>
        </div>
    </div>
    <div class="max-w-7xl mx-auto border-t border-primary/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-500 text-xs">© 2026 El Garaje de las Guitarras. Todos los derechos reservados.</p>
        <div class="flex gap-4 text-xs text-slate-500">
            <a href="#" class="hover:text-primary">Términos de Servicio</a>
            <a href="#" class="hover:text-primary">Política de Privacidad</a>
        </div>
    </div>
</footer>
