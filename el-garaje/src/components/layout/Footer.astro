---

---

<footer
    class="bg-background-dark border-t border-primary/20 pt-16 pb-8 px-4 mt-20"
>
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
        <div class="md:col-span-1">
            <a class="block mb-6" href="/">
                <img
                    src="/logo.jpg"
                    alt="El Garaje de las Guitarras"
                    class="h-24 w-auto object-contain drop-shadow-md"
                />
            </a>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
                Guitarras de gama media y alta en un ambiente cálido, sin apuros
                y distendido.
            </p>
            <div class="flex gap-4">
                <a
                    href="https://ig.me/m/elgarajedelasguitarras"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram"
                    class="w-10 h-10 flex items-center justify-center rounded-sm bg-primary/5 text-slate-400 hover:text-primary hover:bg-primary/10 transition-all border border-primary/10 hover:border-primary/30"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </a>
                <a
                    href="https://www.facebook.com/Alnicoguitars"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Facebook"
                    class="w-10 h-10 flex items-center justify-center rounded-sm bg-primary/5 text-slate-400 hover:text-primary hover:bg-primary/10 transition-all border border-primary/10 hover:border-primary/30"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
                <a
                    href="https://www.youtube.com/@elgarajedelasguitarras"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="YouTube"
                    class="w-10 h-10 flex items-center justify-center rounded-sm bg-primary/5 text-slate-400 hover:text-primary hover:bg-primary/10 transition-all border border-primary/10 hover:border-primary/30"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
                </a>
                <a
                    href="https://wa.me/5491136934444"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="WhatsApp"
                    class="w-10 h-10 flex items-center justify-center rounded-sm bg-primary/5 text-slate-400 hover:text-primary hover:bg-primary/10 transition-all border border-primary/10 hover:border-primary/30"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </a>
            </div>
        </div>

        <div>
            <h4
                class="font-serif text-lg text-slate-100 mb-6 font-bold tracking-wide"
            >
                Catálogo
            </h4>
            <nav aria-label="Catálogo">
                <ul class="flex flex-col gap-4 text-sm text-slate-400">
                    <li>
                        <a
                            href="/categoria/electricas"
                            class="hover:text-primary transition-colors"
                            >Guitarras Eléctricas</a>
                    </li>
                    <li>
                        <a
                            href="/categoria/acusticas"
                            class="hover:text-primary transition-colors"
                            >Guitarras Acústicas</a>
                    </li>
                    <li>
                        <a
                            href="/categoria/bajos"
                            class="hover:text-primary transition-colors"
                            >Bajos</a>
                    </li>
                    <li>
                        <a
                            href="/categoria/amplificadores"
                            class="hover:text-primary transition-colors"
                            >Amplificadores</a>
                    </li>
                </ul>
            </nav>
        </div>

        <div>
            <h4
                class="font-serif text-lg text-slate-100 mb-6 font-bold tracking-wide"
            >
                Información
            </h4>
            <nav aria-label="Información">
                <ul class="flex flex-col gap-4 text-sm text-slate-400">
                    <li>
                        <a
                            href="/sobre-elgaraje"
                            class="hover:text-primary transition-colors"
                            >Sobre El Garaje</a>
                    </li>
                    <li>
                        <a
                            href="/sobre-elgaraje"
                            class="hover:text-primary transition-colors"
                            >Nuestro Garaje</a>
                    </li>
                    <li>
                        <a
                            href="/consignaciones"
                            class="hover:text-primary transition-colors"
                            >Consignaciones</a>
                    </li>
                </ul>
            </nav>
        </div>

        <div>
            <h4
                class="font-serif text-lg text-slate-100 mb-6 font-bold tracking-wide"
            >
                Visitanos
            </h4>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">
                Para probar algún instrumento de nuestro catálogo, solicitanos
                una visita a Nuestro Garaje.
            </p>
            <a
                href="/contacto"
                class="inline-flex h-10 px-6 items-center justify-center rounded-sm bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase hover:bg-primary hover:text-background-dark transition-all border border-primary/50"
            >
                Solicitar Visita
            </a>
        </div>
    </div>
    <div
        class="max-w-7xl mx-auto border-t border-primary/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
    >
        <p class="text-slate-400 text-xs">
            © 2026 El Garaje de las Guitarras. Todos los derechos reservados.
        </p>
        <div class="flex items-center gap-4 text-xs">
            <a
                href="/admin/login"
                class="text-slate-500 hover:text-primary transition-colors flex items-center gap-1.5"
            >
                <span class="material-symbols-outlined text-sm">lock</span>
                Admin
            </a>
            <span class="text-slate-600">|</span>
            <div class="flex gap-4 text-slate-400">
                <a href="#" class="hover:text-primary">Términos</a>
                <a href="#" class="hover:text-primary">Privacidad</a>
            </div>
        </div>
    </div>
</footer>
