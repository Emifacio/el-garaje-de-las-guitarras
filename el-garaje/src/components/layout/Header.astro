---
---
<header
    transition:persist="main-header"
    class="sticky top-0 z-50 flex flex-col gap-2 bg-background-light/98 dark:bg-background-dark/98 p-4 pb-2 border-b border-primary/20 shadow-lg shadow-black/50">
    <div class="flex items-center h-12 justify-between max-w-7xl mx-auto w-full">
        <!-- Mobile Menu Button -->
        <button id="btn-menu" aria-label="Toggle mobile menu" aria-expanded="false"
            class="lg:hidden flex size-12 shrink-0 items-center justify-center text-slate-800 dark:text-slate-200 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-3xl">menu</span>
        </button>

        <!-- Logo -->
        <a href="/"
            class="flex items-center drop-shadow-md">
            <img src="/logo.jpg" alt="El Garaje de las Guitarras" class="h-12 lg:h-16 w-auto object-contain" />
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
            <a href="/categoria/electricas"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors">Eléctricas</a>
            <a href="/categoria/acusticas"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors">Acústicas</a>
            <a href="/categoria/bajos"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors">Bajos</a>
            <a href="/categoria/amplificadores"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors">Amps</a>
            <a href="/categoria/efectos"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors">Efectos</a>
            <a href="/consignaciones"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors border-l border-primary/30 pl-8">Consignaciones</a>
            <a href="/inspecciones"
                class="text-sm font-bold tracking-widest uppercase hover:text-primary transition-colors">Inspecciones</a>
            <a href="/sobre-elgaraje"
                class="text-sm font-bold tracking-widest uppercase text-primary/80 hover:text-primary transition-colors border-l border-primary/30 pl-8">Nuestro Garaje</a>
        </nav>

        <!-- Search / Cart Icons -->
        <div class="flex items-center justify-end gap-2">
            <button type="button" data-role="search-button" aria-label="Search"
                class="flex items-center justify-center h-12 w-12 text-slate-800 dark:text-slate-200 hover:text-primary transition-colors hover:scale-110">
                <span class="material-symbols-outlined text-2xl">search</span>
            </button>
            <button type="button" id="header-cart-btn" aria-label="Shopping Cart"
                class="cart-toggle-btn relative flex items-center justify-center h-12 w-12 text-slate-800 dark:text-slate-200 hover:text-primary transition-colors hover:scale-110">
                <span class="material-symbols-outlined text-2xl">shopping_cart</span>
                <span id="cart-badge" class="absolute top-2 right-1 bg-accent-burgundy text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center hidden">0</span>
            </button>
            <a href="/contacto"
                class="hidden md:flex h-10 px-6 items-center justify-center rounded-sm bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase hover:bg-primary hover:text-background-dark transition-all border border-primary/50 ml-4">
                Contacto
            </a>
        </div>
    </div>
</header>

<script>
    import { getCartItems } from '../../lib/cartStore';

    function initCartBadge() {
        const badge = document.getElementById('cart-badge');
        if (!badge) return;

        function updateBadge() {
            const items = getCartItems();
            if (items.length > 0) {
                badge.textContent = items.length.toString();
                badge.classList.remove('hidden');
                
                // Animate pop
                badge.classList.add('scale-150');
                setTimeout(() => badge.classList.remove('scale-150'), 200);
            } else {
                badge.classList.add('hidden');
            }
        }

        // Keep updated
        window.addEventListener('cart-updated', updateBadge);
        updateBadge();
    }

    document.addEventListener('astro:page-load', initCartBadge);
    initCartBadge(); // For non-transition loads
</script>
