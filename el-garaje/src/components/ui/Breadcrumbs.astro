---
export interface BreadcrumbItem {
  label: string;
  url?: string;
  isCurrent?: boolean;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-slate-400 mb-8" aria-label="Breadcrumb">
  {items.map((item, index) => (
    <div class="flex items-center gap-2">
      {item.url && !item.isCurrent ? (
        <a href={item.url} class="hover:text-primary transition-colors">
          {item.label}
        </a>
      ) : (
        <span class="text-primary" aria-current={item.isCurrent ? 'page' : undefined}>
          {item.label}
        </span>
      )}
      
      {/* Show separator if it's not the last item */}
      {index < items.length - 1 && (
        <span class="material-symbols-outlined text-sm">chevron_right</span>
      )}
    </div>
  ))}
</nav>
