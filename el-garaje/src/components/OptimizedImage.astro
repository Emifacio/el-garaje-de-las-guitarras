---
/**
 * OptimizedImage Component
 * 
 * A wrapper around Astro's Picture component that provides:
 * - Automatic format conversion (WebP, AVIF, JPEG)
 * - Responsive image variants at configured widths
 * - Lazy loading with hero image detection
 * - Automatic width/height attributes
 * - Picture elements with format fallbacks
 * 
 * Requirements: 1.1, 1.3, 1.4, 1.5, 1.6, 5.2, 5.3
 */

import { Picture } from 'astro:assets';
import { imageOptimizerConfig, getLoadingStrategy } from '../config/image-optimizer.config';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  isHero?: boolean;
  class?: string;
  sizes?: string;
  quality?: number;
}

const {
  src,
  alt,
  width,
  height,
  isHero = false,
  class: className,
  sizes,
  quality
} = Astro.props;

// Determine loading strategy based on hero status
const loading = getLoadingStrategy(isHero);
const fetchpriority = isHero ? 'high' : undefined;

// Use configured quality or default from config
const imageQuality = quality || imageOptimizerConfig.quality.webp;

// Generate sizes attribute for responsive images
const defaultSizes = sizes || '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw';

// Astro's Picture component automatically generates:
// - Multiple format variants (AVIF, WebP, fallback)
// - Responsive srcset with configured widths
// - Proper picture/source elements
// - Width and height attributes to prevent CLS
---

<Picture
  src={src}
  alt={alt}
  width={width}
  height={height}
  widths={imageOptimizerConfig.widths}
  formats={['avif', 'webp']}
  loading={loading}
  fetchpriority={fetchpriority}
  class={className}
  sizes={defaultSizes}
  quality={imageQuality}
  fallbackFormat="jpeg"
/>
